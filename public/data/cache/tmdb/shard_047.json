{"version":1,"entries":{"person_1875646_translations":{"at":1772591491251,"data":{"id":1875646,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kang Mi Na, most often credited only as Mina, is a South Korean singer and dancer. She was a member of the South Korean girl group, Gugudan (gu9udan). Mina was popularly known as one of the eleven finalists in the Mnet's survival show, Produce 101, which created the girl group, I.O.I. She made her debut as an actress in the 2017 drama, 20th Century Boy and Girl.","name":"Kang Mi-na","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"강미나","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"姜美娜","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"康美娜","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"康美娜","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Кан Ми На","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Кан Мі На","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}}]}}}}