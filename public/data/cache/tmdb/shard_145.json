in","data":{"biography":"","name":"吕雪凤","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"呂雪鳳","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"呂雪鳳","primary":false}}]}},"tv_198178_detail_vi-VN":{"at":1772689468671,"data":{"adult":false,"backdrop_path":"/ldz9THIHaV4orMsUrPT1nlQF51T.jpg","created_by":[{"id":1237529,"credit_id":"65554490d4fe04011b914422","name":"Andrew Guest","original_name":"Andrew Guest","gender":2,"profile_path":"/s4844Z9kRkNlw9yCth1tKkpzAhC.jpg"},{"id":1144604,"credit_id":"6555448dac416100ad280e66","name":"Destin Daniel Cretton","original_name":"Destin Daniel Cretton","gender":2,"profile_path":"/s8uAUG9egZlRIU0PKNkTkIz9E6g.jpg"}],"episode_run_time":[],"first_air_date":"2026-01-27","genres":[{"id":35,"name":"Phim Hài"},{"id":18,"name":"Phim Chính Kịch"}],"homepage":"https://www.disneyplus.com/browse/entity-555c5896-02e4-4873-8fa9-ce090dcd874b","id":198178,"in_production":false,"languages":["en"],"last_air_date":"2026-01-27","last_episode_to_air":{"id":6594790,"name":"Tập 8","overview":"","vote_average":5.77,"vote_count":37,"air_date":"2026-01-27","episode_number":8,"episode_type":"finale","production_code":"","runtime":35,"season_number":1,"show_id":198178,"still_path":"/4Xa7j3I4LQjkDdTEi3fmR23HKQ5.jpg"},"name":"Wonder Man","next_episode_to_air":null,"networks":[{"id":2739,"logo_path":"/1edZOYAfoyZyZ3rklNSiUpXX30Q.png","name":"Disney+","origin_country":""}],"number_of_episodes":8,"number_of_seasons":1,"origin_country":["US"],"original_language":"en","original_name":"Wonder Man","overview":"Simon và Trevor, hai diễn viên ở hai thái cực khác nhau trong nghề, cả hai đều đang theo đuổi những vai diễn có thể thay đổi hoàn toàn vận mệnh của mình.","popularity":18.0132,"poster_path":"/6yy9nQlFt2l6UVWzrfhszFCaZ5C.jpg","production_companies":[{"id":176762,"logo_path":null,"name":"Kevin Feige Productions","origin_country":"US"},{"id":420,"logo_path":"/hUzeosd33nzE5MCNsZxCGEKTXaQ.png","name":"Marvel Studios","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"seasons":[{"air_date":"2026-01-26","episode_count":8,"id":288697,"name":"Mùa 1","overview":"Simon Williams, một diễn viên triển vọng tại Hollywood, đang chật vật tìm cách đưa sự nghiệp của mình cất cánh. Trong một cuộc gặp gỡ tình cờ với Trevor Slattery, một diễn viên mà những vai diễn huy hoàng nhất có lẽ đều đã nằm lại ở quá khứ, Simon biết được rằng đạo diễn huyền thoại Von Kovak đang thực hiện lại bộ phim siêu anh hùng mang tên \"Wonder Man\".\n\nHai nam diễn viên ở hai đầu đối nghịch của sự nghiệp này đã dấn thân vào một cuộc rượt đuổi quyết liệt cho những vai diễn để đời, đồng thời hé mở cho khán giả một cái nhìn chân thực phía sau bức màn nhung của ngành công nghiệp giải trí.","poster_path":"/z5xlxga7oc2eGVpS9vw38ULA9nr.jpg","season_number":1,"vote_average":5.6}],"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Ended","tagline":"","type":"Miniseries","vote_average":7.156,"vote_count":224}},"person_1416513_translations":{"at":1772689475167,"data":{"id":1416513,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Wu Yufang","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　吴玉芳，演员，毕业于北京电影学院。她的戏路较宽，勇于尝试不同环境不同性格的女性角色。她饰演的与自身有极大反差的陕北农村姑娘刘巧珍，已成为中国电影女性画廊中的经典形象。她的表演注重对人物内在气质的揭示。\n\n　　1984年吴玉芳出演吴天明执导的电影《人生》，饰演女主角刘巧珍，片中的她表演质朴准确，细腻深沉，让她获得了第八届《大众电影》百花奖最佳女演员奖项。1988年与兵乓球运动员江嘉良结婚之后淡出娱乐圈出国深造，1997年做回自由演员，陆续在各类电影、电视剧作品中出演。2019年11月，吴玉芳凭借《送我上青云》中梁美枝一角获得第32届金鸡奖最佳女配角。\n\n　　代表作品有电影《人生》、《冰山下的来客》、《送我上青云》，电视剧《涉外保姆》、《蜗居》、《幸福相依》等。","name":"吴玉芳","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Wu Yufang, nasceu em Xangai, é graduada pela Academia de Cinema de Pequim, é uma atriz da China Continental. Em 1984, Wu Yufang ganhou o prêmio de Melhor Atriz no Oitavo Prêmio de Filme Popular Cem Flores por seu papel no filme \"Life\". Mais tarde, ele participou de muitos trabalhos de cinema e televisão, como \"Woman's Sky\", \"Snail House\", \"Crane Huating\" e \"An Jia\".","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Wu Yufang","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"吳玉芳，演員，畢業於北京電影學院。她的戲路較寬，勇於嘗試不同環境不同性格的女性角色。她飾演的與自身有極大反差的陝北農村姑娘劉巧珍，已成為中國電影女性畫廊中的經典形象。她的表演注重對人物內在氣質的揭示。\n\n1984 年吳玉芳出演吳天明執導的電影《人生》，飾演女主角劉巧珍，片中的她表演質樸準確，細膩深沉，讓她獲得了第八屆《大眾電影》百花獎最佳女演員獎項。1988 年與兵乓球運動員江嘉良結婚之後淡出娛樂圈出國深造，1997 年做回自由演員，陸續在各類電影、電視劇作品中出演。2019 年 11 月，吳玉芳憑藉《送我上青雲》中梁美枝一角獲得第 32 屆金雞獎最佳女配角。\n\n代表作品有電影《人生》、《冰山下的來客》、《送我上青雲》，電視劇《涉外保姆》、《蝸居》、《幸福相依》等。","name":"吳玉芳","primary":false}}]}}}}