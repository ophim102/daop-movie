{"id":1253431,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Takuya Sato (佐藤 拓也, Satō Takuya, May 19, 1984) is a Japanese voice actor and singer from Yamamoto Town, Watari District, Miyagi Prefecture. He is affiliated with Ken Production.\n\nNot to be confused with actor and voice actor affiliated with Production Ace Takuya Sato (里 卓哉).","name":"Takuya Sato","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Takuya Sato (佐藤 拓也, Satō Takuya, 19 de mayo de 1984) es un seiyuu (actor de voz) y cantante japonés de la ciudad de Yamamoto, distrito de Watari, prefectura de Miyagi, que está afiliado a Ken Production.\n\nNo confundir con actor y actor de voz afiliado a Production Ace Takuya Sato (里 卓哉).","name":"Takuya Sato","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"佐藤拓也","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"佐藤拓也","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"사토 타쿠야","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Takuya Sato","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Takuja Sató","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Takuja Sató","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"ทากูยะ ซาโต","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"佐藤拓也","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Ук