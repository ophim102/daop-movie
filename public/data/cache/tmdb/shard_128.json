{"version":1,"entries":{"movie_1562579_detail_vi-VN":{"at":1772469931881,"data":{"adult":false,"backdrop_path":"/Aw9gx0cktEyh5at9DUNjrGrFx6n.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":53,"name":"Phim Gây Cấn"},{"id":27,"name":"Phim Kinh Dị"}],"homepage":"","id":1562579,"imdb_id":null,"origin_country":["CN"],"original_language":"zh","original_title":"巫咒","overview":"Bộ phim chuyển thể từ bí ẩn có thật về “Âm hôn hiến tế”. Tôi theo chân một phóng viên tới vùng đất đen để điều tra “lời nguyền Sơn Thần”, nhưng lại bị cuốn vào điều cấm kỵ kinh hoàng. Quan tài hỷ, chuông thầy cúng thường vang lên giữa đêm, nửa đêm thấy người giấy chuyển động; tỉnh dậy, tôi nằm trong quan tài, đối diện thi thể mở trừng mắt. Cuối cùng, sự thật lộ diện: những cô gái bị trúng tà đều là “cô dâu giấy”. Và tôi đã sớm bị chọn làm vật hiến tế. Khi mặt nạ quỷ của pháp sư áp sát, một tiếng thì thầm lạnh sống lưng vang lên: “Đến lượt ngươi rồi!”","popularity":0.227,"poster_path":"/3WVa5Zt7lrwDrRwURTmqlVlFJNW.jpg","production_companies":[],"production_countries":[],"release_date":"2025-10-11","revenue":0,"runtime":88,"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Released","tagline":"","title":"Vu Chú","video":false,"vote_average":6,"vote_count":1}},"person_1272350_translations":{"at":1772469937705,"data":{"id":1272350,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Boonsong Nakphoo is a Thai film writer, director and actor. He holds a BA in Dramatic Arts from the Faculty of Arts, Chulalongkorn University, and an MA in Film and Digital Arts from the Kasem Bundit University, Bangkok, Thailand.","name":"Boonsong Nakphoo","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"บุญส่ง นาคภู่","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"Boonsong N