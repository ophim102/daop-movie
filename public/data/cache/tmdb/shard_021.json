":"6957729b1579cecae388f635","department":"Production","job":"Associate Producer"},{"adult":false,"gender":0,"id":1193990,"known_for_department":"Directing","name":"Diego Cohen","original_name":"Diego Cohen","popularity":0.1969,"profile_path":null,"credit_id":"695772cd4e0286dddacc8bb9","department":"Editing","job":"Editor"}]}},"movie_1168190_keywords":{"at":1772689457857,"data":{"id":1168190,"keywords":[{"id":9824,"name":"reunion"},{"id":229620,"name":"helicopter chase"},{"id":243959,"name":"brother brother relationship"},{"id":325791,"name":"defiant"},{"id":345457,"name":"loss of father"}]}},"person_38561_translations":{"at":1772689466037,"data":{"id":38561,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kelly Brook (born Kelly Ann Parsons; 23 November 1979) is an English model, actress, entrepreneur, television presenter and Playboy model.","name":"Kelly Brook","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"Настоящее имя — Келли Энн Парсонс. Родилась 23 ноября 1979 года в городе Рочестер, графство Кент, Великобритания. В 17 лет Келли поступила в престижнейшую театральную школу London’s Italia Conti stage school, её родители не могли себе позволить оплачивать обучение дочери, а гранта Келли добиться не удалось. Впрочем, это её не остановило. Чтобы оплачивать обучение, Келли начала подрабатывать моделью для небольших фирм и официанткой в чайном магазине. Наконец, «засветившись» в нескольких мужских журналах, Келли получила маленькую роль на ТВ в шоу «Nicky with the Ticky».\n\nПосле этого шоу Келли пригласили на место ведущей программы «Big Breakfast» и эта передача стала её звездным часом. Продюсеры шоу сомневались, удастся ли Келли легко вписаться в ритм программы и поладить с её ведущим, но у неё это прекрасно получилось. Мало того, скоро она стала одной из главных составляющих успеха шоу: мужчины цепенели при взгляде на пышнотелую красотку в облегающих туалетах. Тем не менее, в 1999 году Келли приняла решение покинуть «Big Breakfast», чтобы, по её словам, проводить больше времени со своим бойфрендом, актёром Джейсоном Стейтемом, за которого она собиралась выйти замуж. Впрочем, Келли недолго сидела без работы. Буквально сразу известная фирма, производитель нижнего белья, предложила ей очень выгодный контракт. Её изображения появились в журналах и на улицах Лондона.\n\nЛюбовь мужских журналов к Келли невероятно прогрессировала. Если в 1998 году авторитетный журнал «FHM» поставил её только на 29 место в списке самых сексуальных женщин мира, то в 1999 году она была уже третьей. И даже то, что в этом же списке в 2000 году Келли заняла пятую строчку, а в 2001 году — четвертую вряд ли её расстроило — ведь журнал «Maxim» поставил её на первое место среди самых сексуальных женщин прошлого века.","name":"","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Kelly Brook est une actrice, scénariste, réalisatrice, coproductrice, productrice et doubleuse anglaise.","name":"","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"英国模特、演员、企业家、电视节目主持人和花花公子模特。","name":"凯莉·布鲁克","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"英國模特、演員、企業家、電視節目主持人和花花公子模特。","name":"凱莉·布魯克","primary":false}}]}},"tv_274548_keywords":{"at":1772689467241,"data":{"id":274548,"results":[{"name":"puberty","id":1525},{"name":"high school","id":6270},{"name":"slice of life","id":9914},{"name":"based on manga","id":13141},{"name":"high school friends","id":18005},{"name":"boys' school","id":185413},{"name":"anime","id":210024},{"name":"japanese high school","id":235790},{"name":"human nature","id":257412},{"name":"gay subtext","id":366740}]}},"tv_275987_keywords":{"at":1772689471741,"data":{"id":275987,"results":[{"name":"martial arts","id":779},{"name":"3d animation","id":278823},{"name":"web series","id":281372},{"name":"donghua","id":315535}]}},"person_2541894_translations":{"at":1772689473382,"data":{"id":2541894,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"胡良伟，内地配音演员，现签约北京光合积木文化传播有限责任公司。\n\n主要配音作品：电视剧《武动乾坤》小炎、《双世宠妃Ⅱ》墨靖轩、《烈火军校》沈君山、《琉璃》若玉、《有翡》谢允 ，动画《天官赐福》慕情/扶摇，广播剧《AWM》于炀、《将进酒》李建恒、《嚣张》林无隅。\n\n2020年12月参加由bilibili出品，猫耳FM联合出品，小梦马文化传媒制作的声音演员竞技节目《我是特优声》，最终成为前五名SSV特优声。","name":"胡良伟","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Liangwei Hu","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Liangwei Hu","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"Ху Лян Вэй (胡良伟) - китайский актёр озвучивания.","name":"Ху Лян Вэй","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"胡良偉，內地配音演員，現簽約北京光合積木文化傳播有限責任公司。\n\n主要配音作品：電視劇《武動乾坤》小炎、《雙世寵妃Ⅱ》墨靖軒、《烈火軍校》沈君山、《琉璃》若玉、《有翡》謝允 ，動畫《天官賜福》慕情/扶搖，廣播劇《AWM》於煬、《將進酒》李建恆、《囂張》林無隅。\n\n2020 年 12 月參加由 bilibili 出品，貓耳 FM 聯合出品，小夢馬文化傳媒製作的聲音演員競技節目《我是特優聲》，最終成為前五名 SSV 特優聲。","name":"胡良偉","primary":false}}]}},"person_6007659_translations":{"at":1772689483421,"data":{"id":6007659,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Tariq Bah","primary":true}}]}}}}