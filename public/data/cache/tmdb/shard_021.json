7vuixQWIybHZ2yuq8mmPDMBe.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Phim Chính Kịch"},{"id":14,"name":"Phim Giả Tượng"},{"id":10749,"name":"Phim Lãng Mạn"}],"homepage":"","id":1328862,"imdb_id":"tt33509780","origin_country":["JP"],"original_language":"ja","original_title":"ファーストキス 1ST KISS","overview":"","popularity":1.4307,"poster_path":"/6CKSVkMr0tl0YVQqszrnQee6M6D.jpg","production_companies":[{"id":882,"logo_path":"/fRSWWjquvzcHjACbtF53utZFIll.png","name":"TOHO","origin_country":"JP"},{"id":39804,"logo_path":"/bT7wDgMpeT7EAewYfWIHs3gWNYE.png","name":"AOI Pro.","origin_country":"JP"},{"id":182161,"logo_path":"/wvG4lK0m76M6jK8WbWkXNecA7SP.png","name":"TOHO Studios","origin_country":"JP"},{"id":8157,"logo_path":"/pEqcMX1aG3JvtDgfh2wNZJLCcb4.png","name":"jeki","origin_country":"JP"},{"id":11849,"logo_path":"/ssKAToULWqC6LJXOJWtd0O3VdV0.png","name":"Lawson","origin_country":"JP"},{"id":170927,"logo_path":"/k8pquRgZwIWvy9qQcSmNGRBBox2.png","name":"Nippon Broadcasting System","origin_country":"JP"}],"production_countries":[{"iso_3166_1":"JP","name":"Japan"}],"release_date":"2025-02-07","revenue":19593569,"runtime":124,"spoken_languages":[{"english_name":"Japanese","iso_639_1":"ja","name":"日本語"}],"status":"Released","tagline":"","title":"ファーストキス 1ST KISS","video":false,"vote_average":7.083,"vote_count":24}},"person_2210389_translations":{"at":1772689439517,"data":{"id":2210389,"translations":[{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"山本真理","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"야마모토 마리","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"Mari Yamamoto是日本女演员和记者。\n\n山本出生于日本，1991年随家人移居伦敦，1994年8岁时回到东京生活。她形容这种经历类似于一个局外人，在那里她“在世界任何地方都被认为是非常日本人”，但在日本本身“还不够日本人”。\n\n山本将在东京的国际基督教大学学习国际关系，在那里她将获得文学学士学位，然后搬到纽约市，在李斯特拉斯伯格戏剧和电影学院学习方法表演。在此期间，她还是跳蚤剧院蝙蝠表演公司的一员。此后，她回到东京，开始从事新闻工作，与美国记者杰克·阿德尔斯坦（Jake Adelstein）一起为《每日野兽》（The Daily Beast）撰写文章。阿德尔斯坦的著作《东京风云》正在被改编成HBO Max的电视连续剧，山本五十六将被招募为该剧的编剧人员。她将成为该系列第二季的制片人。\n\n2022 年，山本在 Apple TV+ 系列《弹珠机》中饰演 Hana。同年，她加入了苹果的《君主：怪物的遗产》的演员阵容。2024 年 3 月，她被选为在电影《出租家庭》中与布兰登·弗雷泽 （Brendan Fraser） 演对手戏。","name":"玛丽·亚马莫托","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"Η Μαρί Γιαμαμότο γεννήθηκε στην Ιαπωνία και μεγάλωσε στο Λονδίνο και το Τόκιο. Είναι εντελώς δίγλωσση στα Ιαπωνικά και τα Αγγλικά. Έχει πτυχίο στις Διεθνείς Σχέσεις από τη ΜΕΘ (Τόκιο) και σπούδασε υποκριτική στο The Lee Strasberg Theater and Film Institute στη Νέα Υόρκη για δύο χρόνια. Ήταν μέλος των The Bats στο The Flea Theatre στην Tribeca NY για αρκετά χρόνια, παίζοντας σε διάφορες παραστάσεις εκτός Μπρόντγουεϊ. Εργάζεται διεθνώς, εμφανιζόμενη σε ταινίες που έγιναν στις ΗΠΑ, την Ελλάδα, τη Σιγκαπούρη, την Ιαπωνία και την Τσεχία.","name":"","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Mari Yamamoto est actrice et productrice. Elle est connue pour Monarch: Legacy of Monsters (2023), Pachinko (2022) et Kate (2021).","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Mari Yamamoto is a Japanese actress and journalist.\n\nBorn in Japan, Yamamoto would move with her family to London in 1991, before eventually returning to live in Tokyo in 1994 at the age of 8. She described the experience as akin to being an outsider, where she'd be considered \"very Japanese everywhere in the world\" but \"wasn’t quite Japanese enough\" in Japan itself.\n\nYamamoto would study international relations at the International Christian University in Tokyo, where she would obtain her Bachelor of Arts, before moving to New York City to study method acting at the Lee Strasberg Theatre and Film Institute. During this time she was also part of The Bats acting company at The Flea Theater. She returned to Tokyo following this, and began working in journalism, writing articles for The Daily Beast alongside American journalist Jake Adelstein. Adelstein's book Tokyo Vice was being adapted into a television series for HBO Max, which would see Yamamoto recruited to work on the show's writing staff. She would become a producer on the series in its second season.\n\nIn 2022, Yamamoto starred in a recurring role in the Apple TV+ series Pachinko as Hana. That same year she would join the cast of Apple's Monarch: Legacy of Monsters. In March 2024, she was cast to star opposite Brendan Fraser in the film Rental Family.","name":"Mari Yamamoto","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"山本真理","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"山本真理 是日本女演員和記者。\n\n山本出生於日本，1991 年隨家人移居倫敦，1994 年 8 歲時回到東京生活。她形容這種經歷類似於一個局外人，在那裏她“在世界任何地方都被認為是非常日本人”，但在日本本身“還不夠日本人”。\n\n山本將在東京的國際基督教大學學習國際關係，在那裏她將獲得文學學士學位，然後搬到紐約市，在李斯特拉斯伯格戲劇和電影學院學習方法表演。在此期間，她還是跳蚤劇院蝙蝠表演公司的一員。此後，她回到東京，開始從事新聞工作，與美國記者傑克·阿德爾斯坦（Jake Adelstein）一起為《每日野獸》（The Daily Beast）撰寫文章。阿德爾斯坦的著作《東京風雲》正在被改編成 HBO Max 的電視聯續劇，山本五十六將被招募為該劇的編劇人員。她將成為該系列第二季的製片人。\n\n2022 年，山本在 Apple TV+ 系列《彈珠機》中飾演 Hana。同年，她加入了蘋果的《君主：怪物的遺產》的演員陣容。2024 年 3 月，她被選為在電影《出租家庭》中與布蘭登·弗雷澤 （Brendan Fraser） 演對手戲。","name":"山本真理","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Марі Ямамото","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"מארי יאממוטו","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Мари Ямамото","primary":false}}]}},"person_1306825_translations":{"at":1772689443523,"data":{"id":1306825,"translations":[{"iso_3166_1":"US","iso_639_