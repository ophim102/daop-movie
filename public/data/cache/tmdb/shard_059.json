f_seasons":1,"origin_country":["JP"],"original_language":"ja","original_name":"真夜中ハートチューン","overview":"Mỗi khi nằm một mình trong đêm, Arisu Yamabuki luôn tìm thấy sự an ủi từ giọng nói ấm áp của nữ phát thanh viên bí ẩn mang biệt danh “Apollo”. Thế nhưng, một ngày nọ cô đột ngột biến mất khỏi làn sóng radio mà không để lại bất kỳ lời giải thích nào. Nhiều năm sau, khi đã là học sinh lớp 11, Arisu quyết tâm tìm lại Apollo vì vẫn còn những điều chưa kịp nói. Dù không biết diện mạo hay tên thật của cô, cậu lần theo những manh mối dẫn mình đến Câu lạc bộ Phát thanh của trường. Tại đây, Arisu gặp bốn cô gái Rikka, Shinobu, Nene và Iko - những người sở hữu chất giọng giống hệt Apollo và cùng nuôi dưỡng ước mơ trở thành phát thanh viên, mở ra hành trình tìm kiếm giọng nói năm xưa với những rung động tuổi trẻ đầy cảm xúc.","popularity":8.3147,"poster_path":"/otKyL6FiAoNAAB90N0cO3RhRhCj.jpg","production_companies":[{"id":184412,"logo_path":"/rMFZqMaUvjaD4ZTAJlHweBS6XcF.png","name":"GEKKOU Production","origin_country":"JP"},{"id":69968,"logo_path":"/cN8Qhl29ZrmWYgkYTS6CDhPK0A5.png","name":"NBCUniversal Entertainment Japan","origin_country":"JP"},{"id":59118,"logo_path":"/9nTCEBgGaaI5swkv8gy2vny0Mb5.png","name":"Kodansha","origin_country":"JP"},{"id":7549,"logo_path":"/bXc1vp0lER6PDHtsVe12pSPwNkv.png","name":"Kansai Television","origin_country":"JP"},{"id":55938,"logo_path":"/ku5PUEwBjUx8XaYikgaXRVLIMbb.png","name":"avex pictures","origin_country":"JP"},{"id":188144,"logo_path":"/tft4KzwjS3okGiN6duB3qwHkIX1.png","name":"BS Asahi","origin_country":"JP"},{"id":98553,"logo_path":"/qqyXcZlJQKlRmAD1TCKV7mGLQlt.png","name":"Crunchyroll","origin_country":"JP"},{"id":36342,"logo_path":"/3xYrMZn6SrupK4R83EUgNPjzqj4.png","name":"Sammy","origin_country":"JP"},{"id":6681,"logo_path":"/s4RElEnQyM2VrHZCQ3jYemPdxML.png","name":"THE KLOCKWORX","origin_country":"JP"}],"production_countries":[{"iso_3166_1":"JP","name":"Japan"}],"seasons":[{"air_date":"2026-01-06","episode_count":12,"id":445457