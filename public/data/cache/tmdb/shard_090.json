h trình ấy của Thạch Mục cũng chẳng hề dễ dàng, gian nan và cũng không thiếu nguy hiểm. Từ những trận chiến thập tử nhất sinh, tưởng hẹo mười mươi, cho đến những ngày tháng bị rượt đuổi chạy như bị Tào Tháo rượt, những những khoảnh khắc ấy đã tôi luyện cho Thạch Mục ngày càng trưởng thành, trở thành một võ giả có thể cứu rỗi tương lai của muôn người.","popularity":9.8538,"poster_path":"/sTCWzoUUQHT36uS9Kt2O3qXGSoM.jpg","production_companies":[{"id":123270,"logo_path":"/4KxfGr13VXMr44og11hzpdwfQDQ.png","name":"bilibili","origin_country":"CN"},{"id":208526,"logo_path":null,"name":"BYMENT","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2025-11-26","episode_count":26,"id":476705,"name":"Season 1","overview":"","poster_path":"/88eylq2rbHMSv4Do9RoFpj5fuFt.jpg","season_number":1,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Returning Series","tagline":"","type":"Scripted","vote_average":8,"vote_count":1}},"movie_1523145_credits":{"at":1772779076287,"data":{"id":1523145,"cast":[{"adult":false,"gender":1,"id":5037367,"known_for_department":"Acting","name":"Veronika Zhuravleva","original_name":"Вероника Журавлёва","popularity":2.4207,"profile_path":"/bvlry6DeiYkm0onAZhonlpl4J7.jpg","cast_id":1,"character":"","credit_id":"688b9c6006851bb0a7948e31","order":0},{"adult":false,"gender":2,"id":5598110,"known_for_department":"Acting","name":"Daniel Vegas","original_name":"Даниэль Вегас","popularity":2.4717,"profile_path":"/t9AFZX1rpTt59npITX2GY3JgySd.jpg","cast_id":2,"character":"","credit_id":"688b9cc6b5470c1740948c64","order":1},{"adult":false,"gender":1,"id":5654199,"known_for_department":"Acting","name":"Alya Mayer","original_name":"Аля Майер","popularity":0.3141,"profile_path":null,"cast_id":11,"character":"","credit_id":"68af8093d242e00c0b624c8b","order":2},{"adult":false,"gender":2,"id":2007622,"known_for_department":"Acting","name":"Maksim Saprykin","ori