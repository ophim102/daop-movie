ing Ran","popularity":0.2927,"profile_path":"/r5jnD2rEJ93KZvfWKhFAMrhooQ9.jpg","character":"Gesang Meiduo","credit_id":"6947e3b945ffc6c5f3155226","order":0},{"adult":false,"gender":2,"id":3112288,"known_for_department":"Acting","name":"Li Jingyi","original_name":"Li Jingyi","popularity":0.3974,"profile_path":"/qZ5msTVtaJLVb8HGEnaQTh05zlj.jpg","character":"Yi Gaoyuan","credit_id":"6947e3be128330a241b1c71c","order":1},{"adult":false,"gender":2,"id":2456847,"known_for_department":"Acting","name":"Ni Hanjin","original_name":"倪寒尽","popularity":0.5743,"profile_path":"/xLOwqZIT9QIcbm9BzX0AGQFdPC0.jpg","character":"Balu Yundan","credit_id":"6947e3ed9926ecda96b1c8c5","order":2},{"adult":false,"gender":1,"id":5890538,"known_for_department":"Acting","name":"Du Meng","original_name":"杜孟","popularity":0,"profile_path":null,"character":"Li Yuling","credit_id":"6947e3f3d44920a6037abf6e","order":3},{"adult":false,"gender":1,"id":3989511,"known_for_department":"Acting","name":"Dong Qianyu","original_name":"董千瑀","popularity":0.2347,"profile_path":null,"character":"Gesang Deji","credit_id":"69486cff5692d556ee1553d2","order":4}],"crew":[],"id":308805}},"person_963313_translations":{"at":1772725230286,"data":{"id":963313,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Holt Boggs was born and raised in Houston, Texas for the most part. The son of a geologist, he and his family traveled the world for several years living in Africa, Indonesia, Singapore and Jakarta before returning to Texas. Shortly there after, his parents got divorced and he and his little brother went to live with their mother back in Houston.\n\nAlways the class clown, Holt first gravitated towards sketch comedy and his ultimate goal was to land a gig on the TV show, 'SNL'. He hit the stage, doing stand-up at the local comedy clubs before auditioning and being accepted into a two-year conservatory program in Dallas.\n\nWhile in the program, Holt did every play, commercial and short film he could, to gain experience. Frustrated with the lack of film work in Dallas, he co-wrote and produced the indie thriller, \"The Prodigy\". The success of this international indie film has kept Holt in demand around the globe where he's gotten to work with some of the biggest names in the business. Holt has since moved to Los Angeles where he has worked on numerous TV and film projects.","name":"Holt Boggs","primary":true}}]}},"person_5941947_translations":{"at":1772725230420,"data":{"id":5941947,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Peter Colandro","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Питер Коландро","primary":false}}]}},"movie_1466115_keywords":{"at":1772725237642,"data":{"id":1466115,"keywords":[{"id":1453,"name":"amnesia"},{"id":818,"name":"based on novel or book"},{"id":9714,"name":"remake"},{"id":156924,"name":"tearjerker"},{"id":269719,"name":"high school romance"},{"id":277551,"name":"slow burn"},{"id":311952,"name":"pure love"},{"id":361444,"name":"emotional growth"},{"id":365954,"name":"emotional"},{"id":366618,"name":"melancholic"},{"id":366619,"name":"youth melodrama"},{"id":366620,"name":"fear of goodbye"},{"id":366621,"name":"warm tragedy"},{"id":366622,"name":"bittersweet ending"},{"id":366623,"name":"tears guaranteed"}]}},"person_1328108_translations":{"at":1772725263966,"data":{"id":1328108,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Geo Dobre","primary":false}},{"iso_3166_1":"RO","iso_639_1":"ro","name":"Română","english_name":"Romanian","data":{"biography":"","name":"Geo Dobre","primary":true}}]}},"tv_128904_keywords":{"at":1772725273656,"data":{"id":128904,"results":[{"name":"detective","id":703},{"name":"based on novel or book","id":818},{"name":"1970s","id":1228},{"name":"new mexico","id":1508},{"name":"indigenous","id":1551},{"name":"investigation","id":5340},{"name":"navajo","id":9524},{"name":"shaman","id":11326},{"name":"witchcraft","id":40931},{"name":"native american reservation","id":155805},{"name":"mysterious","id":197582},{"name":"fbi agent","id":272551},{"name":"slow burn","id":277551},{"name":"gritty","id":286125},{"name":"indigenous customs","id":325100},{"name":"folk magic","id":333109},{"name":"tribal police","id":351207}]}},"person_84508_translations":{"at":1772725280383,"data":{"id":84508,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Takehito Koyasu is a Japanese voice actor. Koyasu is part of the voice actor quartet Weiß consisting of Weiß Kreuz voice castmates Shinichiro Miki, Tomokazu Seki, and Hiro Yūki. He used to work for Production Baobab but is now the head of T's Factory, a voice actor company he founded in 1998.\n\nKoyasu is known for his deep, smooth voice, which often lands him in roles that are either villains or lonely bishōnen. Recently, though (as in the cases of Mitsurugi Hanagata from Saber Marionette J, Ryo Kuroyanagi from Yakitate!! Japan, Bobobo-bo Bo-bobo, and Kei Itoshiki from (Zoku) Sayonara, Zetsubou-Sensei) he has been voicing more and more lively/humorous characters. According to Hisaya Nakajo, the manga artist of the series Hana-Kimi, the character of Masao Himejima was designed with Koyasu's voice in mind; the voice actor ended up voicing this character in the series' drama CDs.\n\nOn 18 September 2009, he created Velvet Underworld series which is the first drama CD of the series, \"The Fool\". In the following month, \"The Wheel of Fortune\" had released as the second drama CD of the series.","name":"Takehito Koyasu","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"子安武人（日语：子安 武人／こやす たけひと Koyasu Takehito，1967年5月5日—），日本男性配音员。出身于日本神奈川县横滨市。身高174cm。A型血。所属事务所为T's Factory。\n\n国中时期原本是想成为电影演员，于是把去学校上课的时间用在看电影看了一整天。直到有一次偶然看了动画《银河铁道999》主角星野铁郎踏上旅途的那一段画面而深受无比感动与幸福。从此对声优产生兴趣，并以“立体性的演技”作为目标。高中毕业之后，进入声优培训学校。\n\n第二代日本声优，连续三年获得最受欢迎男声优。出道作品为《天空戦记 シュラト》，创作了白色猎人。曾与结城比吕、关智一、三木真一郎组成的音乐组合\"Weiβ Kreuz\"。才华横谥，在创造、画画、作曲、填词、小说等领域都有发展。他的成名作也是由他作为主办人将它TV化和组织四人音乐组合与结城比吕、关智一、三木真一郎合作进行。除了令少女们神魂颠倒之外，子安也有创作其他作品例如年头的和近来TV版。","name":"子安武人","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"코야스 타케히토","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"子安武人","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Такэхито Коясу","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"子安武人是日本的男性聲優。出身於神奈川縣橫濱市，畢業於慶應義塾大學理工學院西研究所，所屬公司為 T's Factory。兒子子安光樹也從事配音工作。","name":"子安武人","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Takehito Koyasu","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Takehito Koyasu","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"ทาเกฮิโตะ โคยาซุ","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Takehito Koyasu","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Takehito Kojasu","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Takehito Koyasu","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Takehito Koyasu","primary":false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Takehito Koyasu (子安 武人 Koyasu Takehito, Kanagawa, Japón, 5 de mayo de 1967) es un reconocido actor de voz, cantante y mangaka japonés, siendo uno de los más famosos de Japón, con más de 200 trabajos, entre los cuales se cuentan tanto doblajes en anime como voces de videojuegos. En el ámbito musical se destaca por sus variados trabajos musicales como solista o como artista J-rock bajo el nombre de ZAZEL, o como miembro de la banda Weiss en la que canta en compañía de otros tres actores de voz, Tomokazu Seki, Shinichirō Miki y Hiro Yūki. Uno de sus más grandes logros es la creación del anime Weiss Kreuz, serie de la cual salió la banda anteriormente nombrada. Desde la década de los 2000, Koyasu se ha hecho cargo de muchos de los personajes interpretados por Kaneto Shiozawa tras su muerte.","name":"Takehito Koyasu","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Такехіто Коясу","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"子安武人，日本男性配音員。出身於日本神奈川縣橫濱市。長男子安光樹也從事配音工作。","name":"子安武人","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"טאקהיטו קויאסו","primary":false}}]}},"person_1390040_translations":{"at":1772725284010,"data":{"id":1390040,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Yasunori Danta","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"段田安则","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"段田安則","primary":true}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"",