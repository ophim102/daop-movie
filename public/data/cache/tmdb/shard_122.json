{"version":1,"entries":{"person_2252438_translations":{"at":1772647170911,"data":{"id":2252438,"translations":[{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"JYP엔터테인먼트 소속 5인조 걸그룹 ITZY의 멤버.\n\n2017년 Stray Kids와 믹스나인에 출연과 방탄소년단 LOVE YOURSELF Highlight Reel '起承轉結'에서 제이홉과 지민의 파트너 역으로 얼굴을 알렸고, 2019년 걸그룹 ITZY의 멤버로 데뷔했다.","name":"류진","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Shin Ryu-jin (신류진; born April 17, 2001), known professionally as Ryujin (류진) is a South Korean singer and actress under JYP Entertainment. She is a member of the South Korean girl group ITZY.","name":"Ryujin","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"","primary":false}}]}},"person_1134885_translations":{"at":1772647184028,"data":{"id":1134885,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Omar Rafael Chaparro Alvídrez (Chihuahua, Chihuahua, Mexico; November 26, 1974), better known by his stage name Omar Chaparro, is a Mexican comedian, actor, comedian, singer, composer, producer, lecturer and radio and television host.\n\nHe is known for creating and performing his humorous characters in his radio and television programs where he is also a host, for acting in several Mexican and Mexican-American films and for his double starring role in Netflix's musical comedy film, in tribute to Pedro Infante, Como caído del cielo (Like Fallen from the Sky).\n\nIn addition to being mostly recognized in the Latin dubbing world as the Spanish voice of the panda \"Po\" in the movie Kung Fu Panda and its continuations.\n\nHe also established himself as a singer and has recorded two albums, among them, is his outstanding album entitled Me enamoré de ti, which included his three hits \"Sigues tan hermosa\", \"Me enamoré de ti\" and \"Aferrado\".","name":"Omar Chaparro","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Omar Rafael Chaparro Alvidrez é um ator mexicano, comediante, apresentador de TV, personalidade de mídia e cantor.","name":"","primary":false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Omar Chaparro","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"奥马尔·拉斐尔·查帕罗·阿尔维德雷斯（墨西哥奇瓦瓦州奇瓦瓦州;1974 年 11 月 26 日），以他的艺名奥马尔·查帕罗 （Omar Chaparro） 而闻名，是墨西哥喜剧演员、演员、喜剧演员、歌手、作曲家、制片人、讲师和广播电视主持人。","name":"奥马尔·查帕罗","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"奧馬爾·拉斐爾·查帕羅·阿爾維德雷斯（墨西哥奇瓦瓦州奇瓦瓦州; 1974 年 11 月 26 日），以他的藝名奧馬爾·查帕羅 （Omar Chaparro） 而聞名，是墨西哥喜劇演員、演員、喜劇演員、歌手、作曲家、製片人、講師和廣播電視主持人。","name":"奧馬爾·查帕羅","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Омар Чапарро","primary":false}}]}},"person_1878343_translations":{"at":1772647191614,"data":{"id":1878343,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Dian Sidik","primary":false}},{"iso_3166_1":"ID","iso_639_1":"id","name":"Bahasa indonesia","english_name":"Indonesian","data":{"biography":"","name":"Dian Sidik","primary":true}}]}},"person_2750705_translations":{"at":1772647217292,"data":{"id":2750705,"translations":[{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Janis Abrikh","primary":false}},{"iso_3166_1":"CA","iso_639_1":"fr","name":"F