:false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Carlos Camacho","primary":true}}]}},"person_1580247_translations":{"at":1772689451661,"data":{"id":1580247,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Ben Chase","primary":true}}]}},"movie_1516436_detail_vi-VN":{"at":1772689452659,"data":{"adult":false,"backdrop_path":"/6j9qwdMUGi29psGFLVSImnrjAgu.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Phim Chính Kịch"}],"homepage":"","id":1516436,"imdb_id":"tt37561398","origin_country":["CN"],"original_language":"zh","original_title":"浪浪人生","overview":"Từng một thời hô mưa gọi gió ở thị trấn, “đại ca” Hoàng Vinh Phát nay đã miệng cứng nhưng chân run, bước vào giai đoạn khó khăn của cuộc đời. Thế nhưng, anh cùng gia đình vẫn không để số phận vùi dập. Cậu con trai Hoàng Viễn Đạt bề ngoài tưởng như là người “nhạt nhòa” nhất trong nhà họ Hoàng, nhưng thực chất lại âm thầm toan tính cách làm giàu và “trị cha”. Người vợ Trần Lê Trân thì toàn năng, vượt qua mọi trở ngại, nổi tiếng khắp thị trấn là “mẹ siêu nhân” không dễ động vào. Cô con Hoàng Kiều Kiều liều lĩnh, còn bà cố A Thái lại “thần thông quảng đại”, mỗi người đều tung chiêu riêng mang đến không ít tình huống dở khóc dở cười.","popularity":5.9902,"poster_path":"/a6UA8GTN2PSnommgHgbCgmtdKpd.jpg","production_companies":[{"id":113743,"logo_path":"/r19r2HGaHljSOXYJroM4p6QAW2V.png","name":"Shanghai PMF Media","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"release_date":"2025-09-30","revenue":63200000,"runtime":0,"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Released","tagline":"","title":"Lãng Lãng Nhân Sinh","video":false,"vote_average":7.6,"vote_count":5}},"person_2687220_translations":{"at":1772689455434,"data":{"id":2687220,"translations":[{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Sinh ra trong một gia đình tương đối cơ cực, Tuấn Voi phụ mẹ bán cà phê ngay cầu thang chung cư và anh dành một tình yêu khá lớn cho võ thuật và điện ảnh. Nam diễn viên theo học Taekwondo và biểu diễn để theo đuổi ước mơ cho phim hành động của mình. Những năm khó khăn về kinh tế, Tuấn Voi phải về ở với ông bà nội, tuy nhiên vì niềm đam mê biểu diễn quá lớn mà anh trốn ông bà mình về ở lại với mẹ để đi theo công việc của một diễn viên đóng thế.","name":"Tuấn Voi","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Tuấn Voi","primary":false}}]}}}}