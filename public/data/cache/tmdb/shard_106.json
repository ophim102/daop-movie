{"version":1,"entries":{"person_1429141_translations":{"at":1773369218629,"data":{"id":1429141,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Shoya Chiba (千葉 翔也, Chiba Shōya, August 29, 1995) is a Japanese actor and voice actor (seiyū) from Tokyo. He is affiliated with Toys Factory.","name":"Shoya Chiba","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"치바 쇼야","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"千葉翔也","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"千叶翔也（1995年8月29日－）是日本男性声优及演员（前儿童演员），Sigma Seven所属。\n\n兴趣及专长是吉他、看音乐剧。是宝冢歌剧团的粉丝。\n\n高中时期曾经加入了轻音乐部。\n\n在广播节目“千叶翔也的浪漫千层派”里提到自己崇拜的声优前辈是逢坂良太。","name":"千叶翔也","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Shoya Chiba (千葉 翔也, Chiba Shōya, 29 de agosto de 1995) es un actor y actor de voz (seiyū) japonés de Tokio. Está afiliado a Toys Factory.","name":"Shoya Chiba","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"千葉翔也是日本的男性聲優、前童星。出身於東京都，所屬公司為 TOY'S FACTORY。","name":"千葉翔也","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Shoya Chiba","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Shoya Chiba","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"โชยะ ชิบะ","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Šója Čiba","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"Shoya Chiba (千葉 翔也, Chiba Shōya) è un attore e doppiatore giapponese (seiyū), nato a Tokyo il 29 agosto 1995. È affiliato alla Toys Factory.","name":"Shoya Chiba","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"千葉翔也（1995 年 8 月 29 日－）是日本男性聲優及演員（前兒童演員），Sigma Seven 所屬。\n\n興趣及專長是吉他、看音樂劇。是寶冢歌劇團的粉絲。\n\n高中時期曾經加入了輕音樂部。\n\n在廣播節目“千葉翔也的浪漫千層派”裏提到自己崇拜的聲優前輩是逢坂良太。","name":"千葉翔也","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Шьоя Чіба","primary":false}},{"iso_3166_1":"PH","iso_639_1":"tl","name":"","english_name":"Tagalog","data":{"biography":"Si Shoya Chiba (千葉 翔也, Chiba Shōya, Agosto 29, 1995) ay isang aktor at tagapaglapat ng tinig na nagmula sa Tokyo.","name":"Shoya Chiba","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Шоя Чиба","primary":false}}]}},"person_46691_translations":{"at":1773060336427,"data":{"id":46691,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Teruyuki Kagawa (香川 照之, Kagawa Teruyuki, born December 7, 1965) is a Japanese actor, kabuki actor and boxing commentator.\n\nBorn in 1965, his parents are the kabuki actor Ichikawa Ennosuke III and the cinema actress Yuko Hama. His grandmother is the film actress Sanae Takasugi.\n\nIn the Kabuki world, it is usual for the son of an actor to follow the father's footsteps since very early ages, but his parents divorced in 1968 and his mother was given the custody of him. After that event, he never saw his father again, and his mother refused to give him any training on the Kabuki art and he grew believing that it was \"something that must not be watched\". However he tried several times to meet his biological father. When he was 20, he went to one of his performances and asked if he could see him, stating that he was Ennosuke's son, but when his father's assistants reported to him the situation he refused, stating that he didn't have any son.\n\nHe graduated in social psychology at the University of Tokyo and decided to start a career in cinema.\n\nHe has twice been nominated for the Best Supporting Actor award at the Japanese Academy Awards, once for Warau Iemon and once for Kita no zeronen. He won the award for best supporting actor at the 33rd Japan Academy Prize for Mt. Tsurugidake.","name":"Teruyuki Kagawa","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"香川照之，日本男演員，出身於東京都，六次提名日本電影金像獎最佳男配角。在《暖》中擔任第二男主角扮演啞巴一角，憑此獲得第16屆東京國際電影節最佳男主角獎。他同時是位歌舞伎演員，藝名為九代目市川中車。","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"香川照之，日本演员，毕业于东京大学文学部社会心理学系。\n\n1989年，香川照之在大河剧《春日局》饰演小早川秀秋，自此以演员身份出道。2004年，凭借爱情片《暖》获得第16届东京国际电影节最佳男主角奖。2006年，在吉卜力工作室的动画电影《地海战记》中，香川照之首次挑战了配音演员的工作。2009年，在历史战争片《拉贝日记》中饰演昭和天皇的叔父朝香宫鸠彦亲王（南京大屠杀元凶），获得“拉贝和平奖”。2010年，凭借动作片《剑岳：点之记》获得了第33届日本电影学院奖最佳男配角奖。2011年，香川照之继承九代目市川中车的名号进入歌舞伎界。","name":"香川照之","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"카가와 테루유키","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"香川照之","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Teruyuki Kagawa","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Terujuki Kagawa","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Teruyuki Kagawa","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Teruyuki Kagawa","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Teruyuki Kagawa","primary":false}},{"iso_3166_1":"PT","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Teruyuki Kagawa","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"香川照之，日本演員，畢業於東京大學文學部社會心理學系。\n\n1989 年，香川照之在大河劇《春日局》飾演小早川秀秋，自此以演員身份出道。2004 年，憑藉愛情片《暖》獲得第 16 屆東京國際電影節最佳男主角獎 [1 - 2] 。2006 年，在吉卜力工作室的動畫電影《地海傳説》中，香川照之首次挑戰了配音演員的工作。2009 年，在歷史戰爭片《拉貝日記》中飾演昭和天皇的叔父朝香宮鳩彥親王（南京大屠殺元兇），獲得“拉貝和平獎”。2010 年，憑藉動作片《劍嶽：點之記》獲得了第 33 屆日本電影學院獎最佳男配角獎。2011 年，香川照之繼承九代目市川中車的名號進入歌舞伎界。","name":"香川照之","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Теруюкі Каґава","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Teruyuki Kagawa","primary":false}}]}},"movie_1188227_detail_vi-VN":{"at":1773146659131,"data":{"adult":false,"backdrop_path":"/o1QByvXBD9tPGcqsamhjrG0Q0Xg.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":37,"name":"Phim Miền Tây"}],"homepage":"","id":1188227,"imdb_id":"tt25715918","origin_country":["US"],"original_language":"en","original_title":"The War Between","overview":"","popularity":0.7385,"poster_path":"/xptwPf2CHVM80OUWGPEZC2U443Q.jpg","production_companies":[{"id":210383,"logo_path":"/d1dd6asCeqT1eDBdM2SFWu0MFzf.png","name":"Monsoon Production Services","origin_country":"US"},{"id":210384,"logo_path":null,"name":"The War Between, LLC.","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2025-11-10","revenue":0,"runtime":97,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"The War Between","video":false,"vote_average":8.667,"vote_count":3}},"person_156648_tran