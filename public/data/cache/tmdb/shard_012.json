e está trabajando en Broadway.","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"키티 윈","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"Kitty Winn（1944 年 2 月 21 日出生）是一位屡获殊荣的美国女演员。","name":"吉蒂·温","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"吉蒂·温（1944 年 2 月 21 日出生）是一位屢獲殊榮的美國女演員。","name":"吉蒂·温","primary":false}}]}},"person_5983843_translations":{"at":1772689468031,"data":{"id":5983843,"translations":[{"iso_3166_1":"SE","iso_639_1":"sv","name":"svenska","english_name":"Swedish","data":{"biography":"","name":"Steve Janaszak","primary":true}}]}},"person_2679439_translations":{"at":1772689475081,"data":{"id":2679439,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Dianne Simpson","primary":true}}]}}}}