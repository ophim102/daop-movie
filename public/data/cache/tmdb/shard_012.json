. Ngọc Tuyên đăng kí học hệ bổ túc văn hóa tại trường Trung cấp kinh tế. Ngoài thời gian đi học, để có tiền trang trải anh còn đi làm thêm công việc bảo vệ siêu thị. Vừa đi học vừa đi làm nhưng Ngọc Tuyên thi đỗ 2 trường là Cao đẳng công nghiệp 4 và trường cao đẳng sân khấu điện ảnh thành phố Hồ Chí Minh. Ban đầu, anh học cùng lúc cả hai trường và cả đi làm nhưng sau đó do điều kiện kinh tế và áp lực Ngọc Tuyên chọn theo học tại trường sân khấu điện ảnh.","name":"Quách Ngọc Tuyên","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Quách Ngọc Tuyên","primary":false}}]}},"tv_227477_detail_vi-VN":{"at":1772689457502,"data":{"adult":false,"backdrop_path":"/dNslXm24BxNjk6ZemUGmNIEjPno.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2020-07-10","genres":[{"id":16,"name":"Phim Hoạt Hình"},{"id":10762,"name":"Kids"}],"homepage":"","id":227477,"in_production":true,"languages":["zh"],"last_air_date":"2020-12-23","last_episode_to_air":{"id":4482360,"name":"Episode 26","overview":"","vote_average":0,"vote_count":0,"air_date":"2020-12-23","episode_number":26,"episode_type":"finale","production_code":"","runtime":15,"season_number":4,"show_id":227477,"still_path":"/sXkePQmFEtboEphCDZrBsL7Bp46.jpg"},"name":"猪猪侠之深海小英雄","next_episode_to_air":null,"networks":[{"id":1330,"logo_path":"/fNxBFqWr7eWEgNeBDvvCxsSItXx.png","name":"iQiyi","origin_country":"CN"},{"id":2007,"logo_path":"/6Lfll43wYG2eyereOBjpYFRSGs4.png","name":"Tencent Video","origin_country":"CN"},{"id":3127,"logo_path":"/j2ypJLHH2smn8epaLc6myMM8y8q.png","name":"Aniworld TV","origin_country":"CN"}],"number_of_episodes":104,"number_of_seasons":4,"origin_country":["CN"],"original_language":"zh","original_name":"猪猪侠之深海小英雄","overview":"","popularity":1.0881,"poster_path":"/qQbVvDhH0u4015XlCyZsfCyTpIF.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2020-07-10","episode_count":26