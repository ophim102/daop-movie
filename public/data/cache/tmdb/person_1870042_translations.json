{"id":1870042,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李兰陵，北斗企鹅旗下声优，喜欢茶和唱歌好听的人。声线健气、活泼向上，能自如演绎不同性格的青年角色。对配音拥有极大热忱，是配音界的后起之秀。","name":"李兰陵","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Li Lanling","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"李蘭陵","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李蘭陵，北鬥企鵝旗下聲優，喜歡茶和唱歌好聽的人。聲線健氣、活潑向上，能自如演繹不同性格的青年角色。對配音擁有極大熱忱，是配音界的後起之秀。","name":"李蘭陵","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ли Ланьлинь","primary":false}}]}