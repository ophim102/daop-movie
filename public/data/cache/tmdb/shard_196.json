{"version":1,"entries":{"tv_129272_keywords":{"at":1773369216982,"data":{"id":129272,"results":[{"name":"based on novel or book","id":818},{"name":"3d animation","id":278823},{"name":"cultivation","id":290999},{"name":"donghua","id":315535}]}},"person_66804_translations":{"at":1772779078093,"data":{"id":66804,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Gregory Oliver Hines (February 14, 1946 – August 9, 2003) was an American dancer, actor, choreographer, and singer. He is one of the most celebrated tap dancers of all time. As an actor, he is best known for Wolfen (1981), The Cotton Club (1984), White Nights (1985), Running Scared (1986), A Rage in Harlem (1991), The Gregory Hines Show (1997–1998), playing Ben on Will & Grace (1999–2000), and for voicing Big Bill on the Nick Jr. animated children's television program Little Bill (1999–2004).\n\nHines starred in more than 40 films and also appeared on Broadway. He received many accolades, including a Daytime Emmy Award, a Drama Desk Award, and a Tony Award, as well as nominations for a Screen Actors Guild Award and four Primetime Emmy Awards.\n\nDescription above from the Wikipedia article Gregory Hines, licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Gregory Hines","primary":true}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"グレゴリー・ハインズ","primary":false}}]}},"person_2759476_translations":{"at":1772800773882,"data":{"id":2759476,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Guan Yunpeng","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"管云鹏，1993年1月21日出生于河南省安阳市，毕业于河南大学播音主持专业，中国内地男演员、主持人。\n\n2016年，出演抗战剧《学生兵》，从而进入演艺圈；同年，主演奇幻爱情喜剧电影《恋恋仙缘》。2018年，出演的抗战剧《战天狼》和《浴血十四年》相继播出。2020年，主演的竖屏短剧《假如生活盘了你》。2021年出演影视剧《功勋》，饰演俞庆文。2022年，主演的古装励志剧《梦华录》在腾讯视频播出。2023年，主演的古装轻喜剧《在下李佑》在优酷视频独播。","name":"管云鹏","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Guan Yunpeng","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"관운봉","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"管雲鵬，1993 年 1 月 21 日出生於河南省安陽市，畢業於河南大學播音主持專業，中國內地男演員、主持人。\n\n2016 年，出演抗戰劇《學生兵》，從而進入演藝圈；同年，主演奇幻愛情喜劇電影《戀戀仙緣》。2018 年，出演的抗戰劇《戰天狼》和《浴血十四年》相繼播出。2020 年，主演的豎屏短劇《假如生活盤了你》。2021 年出演影視劇《功勳》，飾演俞慶文。2022 年，主演的古裝勵志劇《夢華錄》在騰訊視頻播出。2023 年，主演的古裝輕喜劇《在下李佑》在優酷視頻獨播。","name":"管雲鵬","primary":false}}]}},"person_3516836_translations":{"at":1773039162924,"data":{"id":3516836,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Cristina Ștefania Codreanu","primary":false}},{"iso_3166_1":"RO","iso_639_1":"ro","name":"Română","english_name":"Romanian","data":{"biography":"","name":"Cristina Ștefania Codreanu","primary":true}}]}},"person_96863_translations":{"at":1773124736473,"data":{"id":96863,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Go Riju","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"日本演员、导演。代表作品有《精彩世界的尽头》、《甜蜜的游泳池畔》等。","name":"利重刚","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"利重剛","primary":true}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Gó Ridžú","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"日本演員、導演。代表作品有《精彩