e":"Turkish","iso_639_1":"tr","name":"Türkçe"}],"status":"Returning Series","tagline":"","type":"Scripted","vote_average":5.5,"vote_count":2}},"person_2509433_translations":{"at":1772647185602,"data":{"id":2509433,"translations":[{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"อาเชน ไอย์ดึน","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Joong Archen Aydin is a model, actor, singer and member of the actor-based project group JASP.ER under GMMTV and Riser Music. Born in Thailand, he moved to Türkiye at eight years old with his mother and stepfather and lived there until he was sixteen. Joong then came back to Thailand to finish his education. He changed his name a number of times before entering show business, including taking his stepfather's surname. He is currently studying broadcasting and streaming media production at Bangkok University's School of Communication Arts.\n\nHe made his acting debut in 2019 with a main role in the series \"2 Moons 2\".\n\nJoong was formerly a member of boy group \"OXQ\" under Motive Village and boy group \"Insight Rookies\" under Insight Entertainment. Joong has been an artist under GMMTV since September 2021. On December 19, 2024, he made his debut with Project JASP.ER with the release of their debut single \"Sadistic\".","name":"Archen Aydin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"阿晨·艾丁","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Joong Archen Aydin","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"阿晨·艾丁","primary":false}}]}},"person_3591947_translations":{"at":1772647196652,"data":{"id":3591947,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Marut Chuenchomboon","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"มารุต ชื่นชมบูรณ์","primary":true}}]}},"person_1588970_translations":{"at":1772647198060,"data":{"id":1588970,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Mat Yeung","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"楊明（英語：Mat Yeung Ming，1981 年 2 月 27 日－），原名楊明，祖父姓楊，父親因過繼給祖母而姓林，後改名林明樂（前藝名揚明），香港男演員及主持，現為無線電視經理人合約藝人，加入無線後多次幹犯刑事罪行。","name":"楊明","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"杨明（英语：Mat Yeung Ming，1981年2月27日－），原名林杨明，祖父姓杨，父亲因过继给祖母而姓林，后改名林明乐（前艺名扬明），香港男演员及主持，现为无线电视经理人合约艺人，加入无线后多次干犯刑事罪行。","name":"杨明","primary":false}}]}},"person_1157358_translations":{"at":1772647198581,"data":{"id":1157358,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Ng Wai-Kwok","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"伍卫国（Lawrence Ng Wai Kwok）有香港电视剧皇帝之称，香港著名演员之一。在80年代的中期，他凭着《马永贞》、《四大名捕》、《再向虎山行》、《少女慈禧》等剧受到内地观众的喜爱。在长达120集的大型古装剧《红楼梦》中，扮演“贾宝玉”，成为唯一一名两次扮演贾宝玉的演员。伍卫国从小的乐趣是画素描，并且学过几年画。生活中的他也是斯文有礼，涵养极佳，待人接物十分得体，在圈中也人缘不错。他的性格内向，不爱出风头，鲜有绯闻传出，加上他自己不爱宣传自己，处事低调，很少有见报机会。","name":"伍卫国","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"伍衛國，有香港電視劇皇帝之稱，香港著名演員之一。在 80 年代的中期，他憑著《馬永貞》、《四大名捕》、《再向虎山行》、《少女慈禧》等劇受到內地觀眾的喜愛。在長達 120 集的大型古裝劇《紅樓夢》中，扮演“賈寶玉”，成為唯一一名兩次扮演賈寶玉的演員。伍衛國從小的樂趣是畫素描，並且學過幾年畫。生活中的他也是斯文有禮，涵養極佳，待人接物十分得體，在圈中也人緣不錯。他的性格內向，不愛出風頭，鮮有緋聞傳出，加上他自己不愛宣傳自己，處事低調，很少有見報機會。","name":"伍衛國","primary":true}}]}},"tv_295483_credits":{"at":1772647203504,"data":{"cast":[{"adult":false,"gender":1,"id":1254300,"know