{"version":1,"entries":{"person_2178031_translations":{"at":1772469925507,"data":{"id":2178031,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Liu Guanlin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"刘冠麟，1981年12月19日出生于黑龙江，毕业于北京舞蹈学院音乐剧系。  2005年，参演电视剧《大汉天子3》，饰演季擒虎。 2008年3月，加盟了宁财神自编自导的12集古装剧《龙虎山客栈》。2011年1月，出演张纪中执导的古装动作戏《菊花醉》 。2013年，刘冠麟加盟了宁财神执导的古装职场轻喜剧《龙门镖局》 。2014年，与秦海璐、胡冰共同主演都市时尚情感作品《妈妈向前冲》  。同年参演电视剧《十月围城》。","name":"刘冠麟","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Liu Guanlin","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"류관린","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Lưu Quán Lân","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"劉冠麟，1981 年 12 月 19 日出生於黑龍江，畢業於北京舞蹈學院音樂劇系。\n\n2005 年，參演電視劇《大漢天子 3》，飾演季擒虎。\n\n2008 年 3 月，加盟了寧財神自編自導的 12 集古裝劇《龍虎山客棧》。2011 年 1 月，出演張紀中執導的古裝動作戲《菊花醉》 。2013 年，劉冠麟加盟了寧財神執導的古裝職場輕喜劇《龍門鏢局》 。2014 年，與秦海璐、胡冰共同主演都市時尚情感作品《媽媽向前衝》 。同年參演電視劇《十月圍城》。","name":"劉冠麟","primary":false}}]}},"person_1175961_translations":{"at":1772469926506,"data":{"id":1175961,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"John Tang Yat-Kwan was born on 24 October 1976. He is an actor, known for Yesteryou, Yesterme, Yesterday, The True Hero","name":"John Tang Yat-Kwan","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"邓一君（John Tang Yat Kwan，1976年10月24日－），前香港童星及演员，九岁时经老师介绍于香港电台教育电视开始演出，曾参与多出电影及电视剧。他曾凭1994年《记得...香蕉成熟时》内杨醒波一角，获提名香港电影金像奖最佳新演员奖。\n\n2005年退出娱乐圈，于宏利金融担任专业理财顾问，其后获擢升为高级分行经理及考取CFP认可财务策划师专业资格。于2006年结婚，育有一女邓颂情（Kristen）。","name":"邓一君","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"鄧一君，前香港演員，九歲時經聖若瑟小學音樂老師介紹於香港電台教育電視開始演出，曾參與多齣電影及電視劇。他曾憑 1994 年《記得. . . 香蕉成熟時》內楊醒波一角，獲提名角逐香港電影金像獎最佳新演員獎。\n\n2005 年退出娛樂圈，其後考取 CFP 認可財務策劃師專業資格，現擔任財富管理公司總監。","name":"鄧一君","primary":true}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Đặng Nhất Quân","primary":false}}]}},"tv_271548_detail_vi-VN":{"at":1772469938417,"data":{"adult":false,"backdrop_path":"/gTPfMUXFIgG6HZeR5hif2fvGzOv.jpg","created_by":[{"id":1584305,"credit_id":"67117d578e844657b7fad79b","name":"Cem Karcı","original_name":"Cem Karcı","gender":2,"profile_path":null}],"episode_run_time":[150],"first_air_date":"2024-11-13","genres":[{"id":18,"name":"Phim Chính Kịch"}],"homepage":"https://www.startv.com.tr/dizi/sahipsizler","id":271548,"in_production":true,"languages":["tr"],"last_air_date":"2026-02-25","last_episode_to_air":{"id":6904304,"name":"Episode 22","overview":"","vote_average":0,"vote_count":0,"air_date":"2026-02-25","episode_number":22,"episode_type":"standard","production_code":"","runtime":125,"season_number":2,"show_id":271548,"still_path":"/zR8mqcrHkPMHqaNyIaYBWsEHjsI.jpg"},"name":"Sahipsizler","next_episode_to_air":{"id":6948067,"name":"Episode 23","overview":"","vote_average":0,"vote_count":0,"air_date":"2026-03-11","episode_number":23,"episode_type":"standard","production_code":"","runtime":null,"season_number":2,"show_id":271548,"still_path":null},"networks":[{"id":778,"logo_path":"/qWvC2SCqIGhm7hPGtqaPjL4tPvx.png","name":"Star TV","origin_country":"TR"}],"number_of_episodes":51,"number_of_seasons":2,"origin_country":["TR"],"original_language":"tr","original_name":"Sahipsizler","overview":"","popularity":23.7168,"poster_path":"/k1FZ5cpY9kDaHrVpCFlZTlkcCkP.jpg","production_companies":[{"id":142312,"logo_path":null,"name":"OGM Pictures","origin_country":"TR"}],"production_countries":[{"iso_3166_1":"TR","name":"Turkey"}],"seasons":[{"air_date":"2024-11-13","episode_count":28,"id":418704,"name":"Season 1","overview":"","poster_path":"/i39pLQ7V5OoBTtZYSEeqP47luxE.jpg","season_number":1,"vote_average":0},{"air_date":"2025-09-10","episode_count":23,"id":473201,"name":"Season 2","overview":"","poster_path":"/8cOiZVmniIKHjQZoDukZu0SFCdO.jpg","season_number":2,"vote_average":0}],"spoken_languages":[{"english_name":"Turkish","iso_639_1":"tr","name":"Türkçe"}],"status":"Returning Series","tagline":"","type":"Scripted","vote_average":5.5,"vote_count":2}},"person_2509433_translations":{"at":1772469950250,"data":{"id":2509433,"translations":[{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"อาเชน ไอย์ดึน","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Joong Archen Aydin is a model, actor, singer and member of the actor-based project group JASP.ER under GMMTV and Riser Music. Born in Thailand, he moved to Türkiye at eight years old with his mother and stepfather and lived there until he was sixteen. Joong then came back to Thailand to finish his education. He changed his name a number of times before entering show business, including taking his stepfather's surname. He is currently studying broadcasting and streaming media production at Bangkok University's School of Communication Arts.\n\nHe made his acting debut in 2019 with a main role in the series \"2 Moons 2\".\n\nJoong was formerly a member of boy group \"OXQ\" under Motive Village and boy group \"Insight Rookies\" under Insight Entertainment. Joong has been an artist under GMMTV since September 2021. On December 19, 2024, he made his debut with Project JASP.ER with the release of their debut single \"Sadistic\".","name":"Archen Aydin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"阿晨·艾丁","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Joong Archen Aydin","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"阿晨·艾丁","primary":false}}]}},"person_3591947_translations":{"at":1772469960952,"data":{"id":3591947,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Marut Chuenchomboon","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"มารุต ชื่นชมบูรณ์","primary":true}}]}},"person_1157358_translations":{"at":1772469961974,"data":{"id":1157358,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Ng Wai-Kwok","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"伍卫国（Lawrence Ng Wai Kwok）有香港电视剧皇帝之称，香港著名演员之一。在80年代的中期，他凭着《马永贞》、《四大名捕》、《再向虎山行》、《少女慈禧》等剧受到内地观众的喜爱。在长达120集的大型古装剧《红楼梦》中，扮演“贾宝玉”，成为唯一一名两次扮演贾宝玉的演员。伍卫国从小的乐趣是画素描，并且学过几年画。生活中的他也是斯文有礼，涵养极佳，待人接物十分得体，在圈中也人缘不错。他的性格内向，不爱出风头，鲜有绯闻传出，加上他自己不爱宣传自己，处事低调，很少有见报机会。","name":"伍卫国","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"伍衛國，有香港電視劇皇帝之稱，香港著名演員之一。在 80 年代的中期，他憑著《馬永貞》、《四大名捕》、《再向虎山行》、《少女慈禧》等劇受到內地觀眾的喜愛。在長達 120 集的大型古裝劇《紅樓夢》中，扮演“賈寶玉”，成為唯一一名兩次扮演賈寶玉的演員。伍衛國從小的樂趣是畫素描，並且學過幾年畫。生活中的他也是斯文有禮，涵養極佳，待人接物十分得體，在圈中也人緣不錯。他的性格內向，不愛出風頭，鮮有緋聞傳出，加上他自己不愛宣傳自己，處事低調，很少有見報機會。","name":"伍衛國","primary":true}}]}},"person_1588970_translations":{"at":1772469976109,"data":{"id":1588970,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Mat Yeung","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"楊明（英語：Mat Yeung Ming，1981 年 2 月 27 日－），原名楊明，祖父姓楊，父親因