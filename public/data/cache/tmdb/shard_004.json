 chỉ sau một đêm. Một con rồng lửa xuất hiện trên bầu trời, thắp sáng màn đêm và phun ra những quả cầu lửa thiêu rụi toàn bộ thao trường, khiến vô số người thương vong. Ngay sau đó, Phù Đồ Thông Thiên cũng bốc cháy dữ dội, hóa thành tro bụi. Cùng lúc ấy, dị tộc theo tà đạo huyên náo ngoài thành, tuyên bố rằng chỉ khi Võ Tắc Thiên noi theo Đức Phật tự thiêu thì thiên hạ mới thoát khỏi tai họa. Trong ngoài thành mọi người đều hoang mang. Địch Nhân Kiệt phụng mệnh điều tra vụ án nhưng lại gặp phải thiếu khanh Đại Lý Tự vốn có hiềm khích với mình Bùi Đông Thăng. Cả hai không đánh không quen, bất đắc dĩ phải cùng nhau phá án. Đối diện với sự xâm lăng của kẻ thù và sự nghi kỵ của đồng đội, Địch Nhân Kiệt quyết liều một phen sống mái, thế sẽ điều tra ra chân tướng vụ án.","popularity":2.7485,"poster_path":"/7pytGAdqDc2NXmiZbg9TAZ37wj7.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"release_date":"2026-03-04","revenue":0,"runtime":0,"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Released","tagline":"","title":"Địch Nhân Kiệt: Phù Đồ Thông Thiên","video":false,"vote_average":1,"vote_count":1}},"movie_417609_credits":{"at":1773319436463,"data":{"id":417609,"cast":[{"adult":false,"gender":0,"id":1856973,"known_for_department":"Acting","name":"Reynaldo Guanche","original_name":"Reynaldo Guanche","popularity":0,"profile_path":null,"cast_id":6,"character":"Esteban","credit_id":"5975d01cc3a368221c00c14b","order":0},{"adult":false,"gender":1,"id":970350,"known_for_department":"Acting","name":"Yuliet Cruz","original_name":"Yuliet Cruz","popularity":0.2528,"profile_path":"/xSHRxnVdpWjUBX92UAuCuvxaWdN.jpg","cast_id":7,"character":"Miriam","credit_id":"5975d02bc3a3685ded02cdaa","order":1},{"adult":false,"gender":0,"id":1645289,"known_for_department":"Acting","name":"Manuel Porto","original_name":"Manuel Porto","popularity":0.1329,"profile_path":null,"cast_id":8,"character":"Hugo","credit_id":"5975d037