}]}},"person_5278611_translations":{"at":1772689465349,"data":{"id":5278611,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Okata Supitchaya","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Okata Supitchaya Na Songkla","primary":false}}]}},"person_1157996_translations":{"at":1772689470041,"data":{"id":1157996,"translations":[{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Thái Hòa sinh ngày 10 tháng 8 năm 1974 tại Sài Gòn. Sau này lớn lên, do có lòng đam mê nghệ thuật nên anh quyết định làm diễn viên hài lẫn diễn viên kịch, cách diễn xuất của Thái Hòa khiến không ít khán giả yêu quý. Không những thế, anh còn đảm nhận luôn vai trò biên kịch sân khấu và đạo diễn sân khấu, hai tác phẩm ăn khách nhất của anh là Người vợ ma và Quả tim máu. Thái Hòa còn lấn sân sang lĩnh vực điện ảnh, bộ phim đầu tiên anh tham gia là phim Những đứa con thành phố, sau này anh gây nhiều ấn tượng với những bộ phim hài của đạo diễn Việt kiều Charlie Nguyễn như là Để Mai tính, Long Ruồi, Cưới ngay kẻo lỡ, Tèo em và Để Mai tính 2. Năm 2004, Thái Hòa có kết hôn với diễn viên hài Cát Phượng rồi cùng cô tham gia nhiều vở hài kịch hay như là Anh chồng nhát, Rình trộm, Tình bạn, Mùa xuân cưới em... Nhưng đến năm 2006 thì cả hai ly hôn khi đã có một đứa con trai. Hiện tại Thái Hòa đang sống với người vợ mới tên Hồng Thu.","name":"Thái Hòa","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Thái Hòa","primary":false}}]}},"tv_289723_detail_vi-VN":{"at":1772689471606,"data":{"adult":false,"backdrop_path":"/6Vr1InH5TksuRSvEGjP2e1oV5ea.jpg","created_by":[],"episode_run_time":[],"first_air_date":"2026-01-28","genres":[{"id":18,"name":"Phim Chính Kịch"},{"id":80,"name":"Phim Hình Sự"}],"homepage":"https://www.iqiyi.com/a_joowt