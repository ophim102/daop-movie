,"person_5981610_translations":{"at":1772689446936,"data":{"id":5981610,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Olivia Sawyer","primary":true}}]}},"person_1121175_translations":{"at":1772689455737,"data":{"id":1121175,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Huỳnh Đông","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Huỳnh Đông","primary":true}}]}},"person_3718807_translations":{"at":1772689459338,"data":{"id":3718807,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Zhang Ruoyu is a female voice actress from China.","name":"Zhang Ruoyu","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"张若瑜是中国内地的女性配音演员。","name":"张若瑜","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Ruoyu Zhang","primary":true}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"張若瑜是中國內地的女性配音演員。","name":"張若瑜","primary":false}}]}},"person_5983841_translations":{"at":1772689467889,"data":{"id":5983841,"translations":[{"iso_3166_1":"SE","iso_639_1":"sv","name":"svenska","english_name":"Swedish","data":{"biography":"","name":"Gary Smith","primary":true}}]}},"person_74946_translations":{"at":1772689475311,"data":{"id":74946,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Huang Lei","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"黄磊，1971年12月6日出生于江西省南昌市，中国大陆男演员、导演、编剧、监制、制片人、歌手、教师、作家。\n\n1990年黄磊考入北京电影学院表演系，同年出演陈凯歌执导电影《边走边唱》。1996年凭借电影《夜半歌声》获得第3届中国长春电影节最佳男配角奖。1997年北京电影学院硕士毕业后留校任教，同年发行第一张音乐专辑《边走边唱》。1999年出演电视剧《人间四月天》，饰演徐志摩。2001年主演电视剧《橘子红了》。2003年自编自导自演第一部电视剧《似水年华》，并发行同名专辑。2004年出版个人随笔集《十七楼的幻想》。2006年主演经典话剧《暗恋桃花源》。2009年主演电视剧《四世同堂》。2011年凭借电视剧《婚姻保卫战》获得第1届亚洲彩虹奖最佳男喜剧演员 。2013年与赖声川等共同发起乌镇戏剧节，同年领衔主演都市情感剧《我爱男闺蜜》 。2015年主演都市情感剧《嘿，老头！》 ，同年参与户外竞技类综艺节目《极限挑战》。2016年主演电视剧《深夜食堂》。2017年5月11日，首次其自编、自导、自演的电影处女作《麻烦家族》全国上映，同年参加生活服务纪实节目《向往的生活》。\n\n2004年3月8日黄磊与孙莉登记结婚。2006年2月6日女儿黄忆慈出生。2014年黄磊透露二女儿已经出生。\n\n2019年8月20日，福布斯中国发布2019名人榜，黄磊位列第63。","name":"黄磊","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"黃磊，出生於江西省南昌市，中國大陸男演員、導演兼製片人、北京電影學院講師、研究生導師、烏鎮國際戲劇節發起人兼總監製、歌手、編劇、作家、主持人、配音。\n\n1990年黃磊出演陳凱歌電影《邊走邊唱》，入圍坎城影展展露頭角；之後出演《夜半歌聲》、《半生緣》和《夜奔》等多部香港文藝電影，名氣漸長；二十一世紀後，轉戰小熒幕和舞台劇，接連出演了《人間四月天》、《橘子紅了》、《暗戀桃花源》、《家》和《四世同堂》等多部民國題材作品，為兩岸三地觀眾熟知；2003年開始自編自導自演電視劇《似水年華》、《天一生水》和《新夜半歌聲》；2004年，與管虎共同執導電視劇《七日》；\n\n2010年後，黃磊的熒幕形象轉型，開始出演喜劇和話題劇，更多關注丁克夫婦、低齡留學、高考、老年痴呆症和婚姻等社會現實問題。期間他的主要作品包括《婚姻保衛戰》、《男人幫》、《夫妻那些事》、《嘿老頭》、《小別離》和《小歡喜》等；2013年他與賴聲川和孟京輝共同發起烏鎮國際戲劇節，目前已成長為亞洲首屈一指的戲劇節；2016年出演蔡岳勳執導電視劇《深夜食堂 (亞洲華語版)》，2016年11月自編自導自演第一部電影《麻煩家族》，影片由香港金牌製作人江志強和日本國寶級導演山田洋次監製。\n\n與此同時，其參與的多部綜藝節目及真人秀，如《爸爸去哪兒》、《非誠勿擾》、《極限挑戰》和《嚮往的生活》都是同時段冠軍收視節目。","name":"黃磊","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Хуан Лэй","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"黃磊，出生於江西省南昌市，中國大陸男演員、導演兼製片人、北京電影學院講師、研究生導師、烏鎮國際戲劇節發起人兼總監製、歌手、編劇、作家、主持人、配音。\n\n1990 年黃磊出演陳凱歌電影《邊走邊唱》，入圍坎城影展展露頭角；之後出演《夜半歌聲》、《半生緣》和《夜奔》等多部香港文藝電影，名氣漸長；二十一世紀後，轉戰小熒幕和舞台劇，接聯出演了《人間四月天》、《橘子紅了》、《暗戀桃花源》、《家》和《四世同堂》等多部民國題材作品，為兩岸三地觀眾熟知；2003 年開始自編自導自演電視劇《似水年華》、《天一生水》和《新夜半歌聲》；2004 年，與管虎共同執導電視劇《七日》；\n\n2010 年後，黃磊的熒幕形象轉型，開始出演喜劇和話題劇，更多關注丁克夫婦、低齡留學、高考、老年痴呆症和婚姻等社會現實問題。期間他的主要作品包括《婚姻保衞戰》、《男人幫》、《夫妻那些事》、《嘿老頭》、《小別離》和《小歡喜》等；2013 年他與賴聲川和孟京輝共同發起烏鎮國際戲劇節，目前已成長為亞洲首屈一指的戲劇節；2016 年出演蔡嶽勳執導電視劇《深夜食堂 (亞洲華語版)》，2016 年 11 月自編自導自演第一部電影《麻煩家族》，影片由香港金牌製作人江志強和日本國寶級導演山田洋次監製。\n\n與此同時，其參與的多部綜藝節目及真人秀，如《爸爸去哪兒》、《非誠勿擾》、《極限挑戰》和《嚮往的生活》都是同時段冠軍收視節目。","name":"黃磊","primary":false}}]}},"person_2682103_translations":{"at":1772689483905,"data":{"id":2682103,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Pop singer, film and television actress in Mainland China.  Member of the female singing group KOGIRLS","name":"Zhao Yaoke","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"趙堯珂","name":"趙堯珂","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"　　可米经纪旗下艺人。四川成都人，2017年2月14日，网络剧《我与你的光年距离》播出，在剧中饰演Li sa，2017年6月，参演电视剧《国民老公》。6月19日《终极三国2017》播出，在剧中饰演貂蝉。同年11月21日，加入女子音乐团体KOGIRLS。","name":"赵尧珂","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"조요가","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"趙堯珂","name":"趙堯珂","primary":false}}]}}}}