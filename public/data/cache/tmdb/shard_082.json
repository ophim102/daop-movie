{"version":1,"entries":{"person_588175_translations":{"at":1772689423124,"data":{"id":588175,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"DK","iso_639_1":"da","name":"Dansk","english_name":"Danish","data":{"biography":"Lars Kristian Ranthe (født 26. august 1969 på Vesterbro i København) er en dansk skuespiller.\n\nEfter endt uddannelse fra Odense Teater i 1998, har han siden medvirket i flere danske film og tv-serier, såsom Se til venstre, der er en svensker (2003), Forbrydelser (2004), Adams æbler (2005), Sommer (2008), Pagten (2009), Dirch (2011), Jagten (2012), Dicte (2013-2016), Kollektivet (2016), Der kommer en dag (2016), Badehotellet (2013-2024) og Druk (2020). For sine præstationer har han modtaget flere Bodil- og Robert-nomineringer, og han modtog for sin gennembrudsrolle som komikeren Kjeld Petersen i filmen Dirch både en Bodil- og Robert-pris i kategorien bedste mandlige birolle.","name":"Lars Ranthe","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"拉尔斯·兰特","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"拉爾斯·蘭特","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ларс Ранте","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Ларс Ранте","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ラース・ランゼ","primary":false}}]}},