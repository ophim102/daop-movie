s":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"郭柏妍，2020年香港小姐季军。\n\n郭柏妍于香港成长，她早年曾就读于圣公会青衣邨何泽芸小学和东华三院吴祥川纪念中学，在学期间曾为该校步操乐团成员，并在“香港步操乐团公开赛”中获得2011年度银奖及2012年度金奖，而她在校内亦曾担任图书馆领袖生副队长及精神健康大使，又曾代表学校多次参与学界游泳比赛并打入八强，及于2013年度香港学校朗诵节取得中五级女子粤语诗词独诵优异奖。中学毕业后，她就读香港高等教育科技学院的食品安全学科，并毕业于香港大学食物安全管理硕士课程。\n\n郭柏妍于2020年参加该年度的《香港小姐竞选》，她表示参选是希望能作更广泛的学习和多认识新朋友，最后在8月30日举行的决赛中夺得季军。她于同年9月初成为无线电视经理人合约艺员，首部参演的剧集为《白色强人II》。","name":"郭柏妍","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Rosita Kwok","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"郭柏姸，香港女演員，《2020 香港小姐競選》季軍，《萬千星輝頒獎典禮 2022》「飛躍進步女藝員」獎項得主，現為無綫電視經理人合約藝員。","name":"郭柏姸","primary":true}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Quách Bách Nghiên","primary":false}}]}},"tv_48146_keywords":{"at":1772725176042,"data":{"id":48146,"results":[{"name":"marriage","id":6038},{"name":"terminal illness","id":6564},{"name":"romance","id":9840},{"name":"misunderstanding","id":12541}]}},"person_123820_translations":{"at":1772725185175,"data":{"id":123820,"translations":[{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"김상호","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kim Sang-ho (김상호) is a South Korean actor. He was born on July 24, 1970.","name":"Kim Sang-ho","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"金相浩（韩语：김상호，1970年7月24日－），韩国男演员，其他译名金相镐、金尚昊。\n\n2007年：青龙电影奖－最佳男配角\n\n2012年：KBS演技大赏－男配角奖（顺藤而上的你）","name":"金相浩","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"金相浩","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"