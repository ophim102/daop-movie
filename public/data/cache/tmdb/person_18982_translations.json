{"id":18982,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Theodore Martin 'Ted' McGinley (born May 30, 1958) is an American actor. He is known for his roles as Jefferson D'Arcy on the television sitcom Married... with Children, and as Charley Shanowski on the ABC sitcom Hope & Faith. He was a late regular on Happy Days, Dynasty and The Love Boat and is known for playing the villainous role of Stan Gable in the film Revenge of the Nerds and in several made-for-television sequels.\n\nHe has been married to actress Gigi Rice since 1991.","name":"Ted McGinley","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"טד מק'גינלי","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"テッド・マッギンレー","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"","name":"Τεντ ΜακΓκίνλεϊ","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"تد مک گینلی","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Тед МакГинли","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"테드 맥긴리","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"تيد ماكجينلي","primary":false}}]}