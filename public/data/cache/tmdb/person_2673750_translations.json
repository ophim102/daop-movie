{"id":2673750,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Myha'la Jael Herrold (/maɪˈhɑːlə/; born April 6, 1996) is an American actress, known mononymously as Myha'la. She is known for her role as Harper Stern in the British television drama Industry and her role as Jordan in the comedic horror film Bodies Bodies Bodies. She acted primarily in theater roles before being cast in Industry, including on the Broadway production of The Book of Mormon.","name":"Myha'la","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"마할라 헤럴드","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"米哈拉·赫罗德","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"マイハラ","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Майгала Герролд","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"米哈拉·赫洛迪文","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Майгала Герролд","primary":false}}]}