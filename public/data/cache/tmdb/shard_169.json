39_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Phan Bân Long","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"潘斌龍，出生於黑龍江省雞西市，中國內地影視演員、相聲小品演員。師從相聲表演藝術家馮鞏，戲劇表演藝術教育家常莉。畢業於中央戲劇學院相聲表演班。\n\n2004 年，考入中央戲劇學院相聲表演班。2005 年，參加北京電視台全國相聲小品邀請賽並獲得一等獎。2008 年，第一次登上中央電視台春節聯歡晚會的舞台並表演相聲劇《公交協奏曲》，飾演上錯車的老太太。2009 年 1 月 19 日，在北京電視台春節聯歡晚會上表演的相聲劇《返鄉》。\n\n2012 年，擔任黑龍江衞視喜劇類綜藝節目《快樂都市之愛笑會議室》主要演員。2013 年，主演黑色幽默電影《一路狂奔》。2014 年主演電影《煎餅俠》飾演大鵬助理董成龍。2016 年參加《歡樂喜劇人第二季》，與崔志佳組合，並憑藉小品《人父心事》奪得了第一期冠軍，從而受到更多關注。2018 年，潘斌龍參演喜劇電影《無名之輩》。","name":"潘斌龍","primary":false}}]}},"person_5144265_translations":{"at":1772689479568,"data":{"id":5144265,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Saiko Kunisawa","primary":true}}]}},"movie_1116201_detail_vi-VN":{"at":1772689480849,"data":{"adult":false,"backdrop_path":"/gqGQ0zADV5FIcgMWtWX8FcGQjFp.jpg","belongs_to_collection":null,"budget":3000000,"genres":[{"id":27,"name":"Phim Kinh Dị"},{"id":878,"name":"Phim Khoa Học Viễn Tưởng"},{"id":9648,"name":"Phim Bí Ẩn"}],"homepage":"","id":1116201,"imdb_id":"tt27564844","origin_country":["US"],"original_language":"en","original_title":"Iron Lung","overview":"Một đại dương máu. Hy vọng cuối cùng còn sót lại sau Đại Tận Diệt Lặng Im. Trong những hành lang rỉ sét của các trạm không gian đang sụp đổ, tàn dư cuối cùng của nhân loại chế tạo một chiếc tàu ngầm để thăm dò những tầng sâu đang chảy máu… và hàn kín một linh hồn bên trong để điều khiển nó. Nhưng hy vọng nơi hư vô này mong manh chẳng khác gì ánh sao xa xôi. Đây không phải một chuyến thám hiểm. Đây là một bản án tử hình.","popularity":9.9635,"poster_path":"/sIwakdbMGS1krtgendTWpxTY9Hw.jpg","production_companies":[{"id":136234,"logo_path":null,"name":"Markiplier Studios","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2026-01-