n_for_department":"Sound","name":"Marina Chabata","original_name":"茶畑満里奈","popularity":0.1032,"profile_path":null,"credit_id":"69682e3f8b49a0bb65f406bd","department":"Sound","job":"Music Producer"},{"adult":false,"gender":1,"id":5557015,"known_for_department":"Sound","name":"Mai Yasuda","original_name":"安田舞","popularity":0.1288,"profile_path":null,"credit_id":"69682e448a7fd3392ee70db1","department":"Sound","job":"Sound Mixer"},{"adult":false,"gender":2,"id":1806063,"known_for_department":"Sound","name":"Naoto Yamaya","original_name":"山谷尚人","popularity":0.3093,"profile_path":null,"credit_id":"69682e484fad23a4c7f40693","department":"Sound","job":"Sound Effects"},{"adult":false,"gender":2,"id":3498274,"known_for_department":"Editing","name":"Takayuki Miyai","original_name":"宮井堂行","popularity":0.4033,"profile_path":null,"credit_id":"69682e500f65951f32dbcd42","department":"Editing","job":"Online Editor"},{"adult":false,"gender":2,"id":2723581,"known_for_department":"Editing","name":"Kuniyuki Ohnishi","original_name":"大西邦侑","popularity":0.2948,"profile_path":null,"credit_id":"69682e54031a03858e078923","department":"Editing","job":"Online Editor"}],"id":249907}},"person_233590_translations":{"at":1772647188471,"data":{"id":233590,"translations":[{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"Yoshitsugu Matsuoka est un seiyū (doubleur) japonais.","name":"Yoshitsugu Matsuoka","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Yoshitsugu Matsuoka is a Japanese voice actor from Hokkaido. He is affiliated with I'm Enterprise. He was honored at the 6th Seiyu Awards for Best New Actor in 2012 and the 10th Seiyu Awards for Best Lead Actor in 2016. He is best known for being the voice of Kirito from Sword Art Online, Sorata Kanda from The Pet Girl of Sakurasou, Sora from No Game No Life, Arata Kasuga/Astral Trinity from Trinity Seven, Sōma Yukihira from Food Wars!: Shokugeki no Soma, and Masamune Izumi from Eromanga Sensei. As of June 17, 2019, he is the current official Guinness World Record holder for the most unique sound bites provided by a voice actor at an exceeded 10,000 words in Danmachi - Memoria Freese.","name":"Yoshitsugu Matsuoka","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"松冈祯丞（日语：松岡 禎丞／まつおか よしつぐ Matsuoka Yoshitsugu，1986年9月17日—）是一名日本男性声优，北海道出身，目前隶属于I'm Enterprise事务所。\n\n松冈祯丞出生于北海道十胜综合振兴局带广市，小学二年级搬家到附近的池田町。因为家附近地广人稀，当时网络也不发达，松冈童年有空会和朋友一起在郊外探险、抓独角仙之类充满自然感的生活。除此之外，松冈小学时期已经有订阅汽车杂志，同时受《头文字D》等动画熏陶，直到高中三年生之前仍然立志要成为汽车检修员。然而他在15岁的时候，于朋友推荐下观看了动画《新世纪福音战士》，并被动画中为渚薰配音的石田彰之演技所震惊，自此对声优这个职业产生了兴趣。松冈高中时本来在修读汽车修理相关的科系，但到高中三年级时希望挑战一下人生，于是在自学一番后进了北海道的声优学校体验一段时间。松冈后来被告知“不去东京的话很难成为专业声优”，于是决意上京，高中毕业后透过新闻奖学生制度加入了日本播音演技研究所。父亲最初反对松冈上京，但最后在“22岁前不能当上声优就要放弃”和“不会给你任何援助”的两个条件下让步。在上京初期，松冈因为没有钱的关系而需要过着半工读的宿舍生活，直到2009年才通过甄选加入I'm Enterprise事务所，当时刚好是22岁。同年，正式以《东之伊甸》“AKX20000”一役出道。","name":"松冈祯丞","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"松岡禎丞","primary":true}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"É um dublador japonês de Hokkaido. Ele é afiliado à I'm Enterprise. Ele foi homenageado no 6º Seiyu Awards de Melhor Ator Novo em 2012 e no 10º Seiyu Awards de Melhor Ator Principal em 2016. Ele é mais conhecido por ser a voz de Kirito do Sword Art Online, Sorata Kanda da Pet Girl of Sakurasou, Sora de No Game No Life, Arata Kasuga / Trinity Astral de Trinity Seven, Sōma Yukihira de Food Wars !: Shokugeki no Soma e Masamune Izumi de Eromanga Sensei. Em 17 de junho de 2019, ele é o atual detentor oficial do Guinness World Record das mordidas de som mais exclusivas fornecidas por um dublador com mais de 10.000 palavras em Danmachi - Memoria Freese.","name":"Yoshitsugu Matsuoka","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Yoshitsugu Matsuoka","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"松岡禎丞是日本的男性聲優。出身於北海道帶廣市，所屬公司為 I'm Enterprise。","name":"松岡禎丞","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"마츠오카 요시츠구","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"โยชิตสึงุ มัตสึโอกะ","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Yoshitsugu Matsuoka","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ёсицугу Мацуока","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Jošicugu Macuoka","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Yoshitsugu Matsuoka","primary":false}},{"iso_3166_1":"PT","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Yoshitsugu Matsuoka","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"Йошіцуґу Мацуока — японський актор озвучування з Хоккайдо. Він пов’язаний з I'm Enterprise.\n\nЙого було відзначено на 6-й церемонії вручення премії «Сейю» за найкращого нового актора в 2012 році та на 10-й церемонії вручення премії «Сейю» за найкращу чоловічу роль у 2016 році.\n\nСтаном на 17 червня 2019 року він є поточним офіційним рекордсменом Книги рекордів Гіннеса за найбільш унікальними звуковими фрагментами, озвученими актором із понад 10 000 слів у Danmachi - Memoria Freese.","name":"Йошіцуґу Мацуока","primary":false}},{"iso_3166_1":"EE","iso_639_1":"ee","name":"Èʋegbe","english_name":"Ewe","