{"id":2220797,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Yohei Azakami","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"阿座上洋平是日本的男性聲優，舊藝名為細野洋平。出身於群馬縣，所屬公司為青二製作。","name":"阿座上洋平","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"阿座上洋平","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Yohei Azakami","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"阿座上洋平（日语：阿座上 洋平／あざかみ ようへい Azakami Yōhei，1991年8月7日—），日本男性配音员。出身于群马县。青二Production所属。旧艺名细野洋平（日语：細野 洋平／ほその ようへい Hosono Yōhei）。身高180cm。\n\n阿座上洋平在观看了《攻壳机动队》后，被剧中冷酷而粗犷的角色所震撼，心想“我也想演那样的角色”，于是决定成为一名配音员。\n\n青二塾东京校第31期毕业。\n\n2012年1月25日，当他还是Junior的成员时，他将自己的艺名从“细野洋平”改为“阿座上洋平”。“阿座上”来自他母亲的娘家姓。\n\n2016年，以《黑骸》里的青马剑之介时贞一角首次主演。\n\n2024年1月1日，他在自己的X（前Twitter）上宣布与同所属经纪公司的大和田仁美结婚。\n\n同年3月，他以《机动战士钢弹 水星的魔女》中的盖尔·杰特克一角获得第18届声优Awards最佳男配角奖。","name":"阿座上洋平","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Yohei Azakami","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"아자카미 요헤이","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ёхэй Адзаками","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"โยเฮ อาซากามิ","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Jóhei Azakami","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Yohei Azakami","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Йохей Адзакамі","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"阿座上洋平，日本男性配音員。出身於群馬縣。舊藝名：阿座上洋平。","name":"阿座上洋平","primary":false}}]}