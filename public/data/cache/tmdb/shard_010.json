{"version":1,"entries":{"person_4738228_translations":{"at":1772469928254,"data":{"id":4738228,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Lox Pratt is a British actor known for his breakout lead role as bad boy 'Jack' in BBC's Lord of the Flies and 'Draco Malfoy' in HBO's Harry Potter series.","name":"Lox Pratt","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TR","iso_639_1":"tr","name":"Türkçe","english_name":"Turkish","data":{"biography":"2012'de İngiltere'nin Cornwall Bölgesi'nde dünyaya gelen Lox Pratt, ilk oyunculuğunu 2024'te Malezya'da çekilen ve Şubat 2026'da yayına giren Sineklerin Tanrısı dizisinde yaptı. Dört bölümlük mini diziyle olumlu yorumlar alan Pratt, HBO'nun 2027'de yayına girmesi planlanan Harry Potter dizisinde Draco Malfoy rolüyle yer alacağını 45 bin takipçili Instagram hesabından duyurdu.\n\nRöportajlarında erken yaşlarda hikaye anlatmaya, film çekmeye, dans etmeye ve yazmaya ilgi duyduğunu ve bunun da kendisini oyunculuğa yönlendirdiğini söyleyen Pratt; yerel bir tiyatro grubuna katıldıktan sonra açık bir oyuncu seçimine alındı. Böylelikle Sineklerin Tanrısı'nda ilk büyük rolünü kazandı. Pratt, ayrıca gelecekte yönetmenlik ve senaristlik alanlarında da çalışmalar yapmak istediğini ifade etti.\n\nLox ve diğer çocuk oyuncuların eğitimlerinin büyük bir bölümünü Londra'nın kuzeyindeki Watford'da bulunan Warner Bros'un Leavesden stüdyosunda kurulacak bir mini okuldaki öğretmenlerden alacaklar. HBO'nun CEO'sunun yaptığı açıklamaya göre dizi, 10 yıl boyunca kesintisiz devam edecek. Çocuk oyuncular ergenliklerini, sınav hazırlıklarını, replik ezberlerini ve daha bir çok şeyi set karavanlarında geçirecekler.\n\nÜç erkek kardeşe sahip olan mavi gözlü sarışın Lox; bateri çalmayı, şarkı söylemeyi, dans etmeyi, sörf yapmayı ve kaykay kaymayı seviyor.","name":"","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Локс Пратт","primary":false}}]}},"person_5640869_translations":{"at":1772469929682,"data":{"id":5640869,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kai Wilson","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Кай Уилсон","primary":false}}]}},"tv_295366_credits":{"at":1772469938635,"data":{"cast":[{"adult":false,"gender":2,"id":1885279,"known_for_department":"Acting","name":"Kohei Amasaki","original_name":"天﨑滉平","popularity":1.6752,"profile_path":"/tnN5jLiLjcDa7qn88uLb1iAfivL.jpg","character":"Yoki (voice)","credit_id":"6868311f6651939fb8702096","order":0},{"adult":false,"gender":1,"id":119143,"known_for_department":"Acting","name":"Kana Hanazawa","original_name":"花澤香菜","popularity":4.3604,"profile_path":"/5bK9ttcRydQBWmyZp7gXDmJYOPF.jpg","character":"Cecilia (voice)","credit_id":"686831355a3c40c60053f197","order":1}],"crew":[{"adult":false,"gender":2,"id":3125534,"known_for_department":"Directing","name":"Tomonori Mine","original_name":"峯友則","popularity":0.1992,"profile_path":null,"credit_id":"68ab7c93eab92453cb6ce841","department":"Directing","job":"Series Director"},{"adult":false,"gender":2,"id":1848755,"known_for_department":"Directing","name":"Yasutaka Yamamoto","original_name":"山本靖貴","popularity":0.4256,"profile_path":"/w7UxMABrQXFDvCg9dluQxvtHJUF.jpg","credit_id":"68ab7cc3eec42045218d2083","department":"Production","job":"General Manager"},{"adult":false,"gender":1,"id":1608126,"known_for_department":"Writing","name":"Yukie Sugawara","original_name":"菅原雪絵","popularity":0.3918,"profile_path":null,"credit_id":"68ab7ce2ce6d589e929dafbf","department":"Writing","job":"Series Composition"},{"adult":false,"gender":1,"id":1862067,"known_for_department":"Visual Effects","name":"Mina Oosawa","original