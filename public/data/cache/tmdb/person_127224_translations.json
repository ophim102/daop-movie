{"id":127224,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Kyūsaku Shimada is a Japanese actor. He was originally part of the Tokyo Grand Guignol Theater group, formed by artist Norimizu Ameya. He stayed with the group until its dissolution in 1986. One of the productions the group undertook was an adaptation of the occult novel Teito Monogatari (Hiroshi Aramata) where Shimada played the lead role Yasunori Kato. He has appeared in films such as Makoto Shinozaki's 0093: Her Majesty's Masao Kusakari and Takahisa Zeze's Pandemic.","name":"Kyūsaku Shimada","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Kyūsaku Shimada","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"岛田久作","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"嶋田久作","primary":true}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Kjúsaku Šimada","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"Kyūsaku Shimada","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Kyūsaku Shimada","primary":false}},{"iso_3166_1":"IT","iso_639_1":"it","name":"Italiano","english_name":"Italian","data":{"biography":"","name":"Kyūsaku Shimada","primary":false}},{"iso_3166_1":"PT","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Kyūsaku Shimada","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Kjúsaku Šimada","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"bi