n_for_department":"Acting","name":"Kwan Ching","original_name":"關菁","popularity":0.6484,"profile_path":"/9ItgkyBLMuR1GZZ3WUJMT85HgnS.jpg","character":"","credit_id":"6443919a05822405133293cb","order":18},{"adult":false,"gender":2,"id":1615354,"known_for_department":"Acting","name":"Lee Yiu-King","original_name":"李耀敬","popularity":0.3719,"profile_path":"/cxT0uwf96a31jUp0bvF6uDZLsVO.jpg","character":"","credit_id":"644391a0651fcf5b8a9d0d74","order":19},{"adult":false,"gender":2,"id":3767367,"known_for_department":"Acting","name":"Tin Wai Yu","original_name":"虞天偉","popularity":0.4602,"profile_path":"/bfVAnsee50IRuT5D8mvQwbsCyRd.jpg","character":"","credit_id":"644391a7d35dea04d9fb784d","order":20}],"crew":[],"id":109441}},"person_228194_translations":{"at":1772647222702,"data":{"id":228194,"translations":[{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jorgito \"Jorge\" Vargas Jr. (born September 29, 1977) is a Canadian actor best known for his role as Blake Bradley, the Navy Thunder Ranger on the television series Power Rangers Ninja Storm. Vargas is skilled in martial arts, skateboarding, skiing and soccer.\n\nVargas has an Argentine mother and a Bolivian father, Jorgito Vargas Sr.  From Wikipedia, the free encyclopedia","name":"Jorge Vargas","primary":true}}]}},"person_172156_translations":{"at":1772647229344,"data":{"id":172156,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Patch Darragh graduated with honors from Juilliard and began his career playing significant roles in award-winning new plays and revivals at many of the countries top regional theaters, as well our foremost theaters both on and off-Broadway. He has accrued an extensive list of TV credits, more recently on the award winning HBO series SUCCESSION on which he played WayStar Royco board member, Ray Kennedy from Season two to Season four. Patch also had notable arcs on LAW & ORDER: SVU, MR. MERCEDES, THE LOUDEST VOICE, THE PATH, LONGMIRE, BOARDWALK EMPIRE & KALEIDOSCOPE. He's perhaps best known as the lovable Dad on the Netflix cult hit EVERYTHING SUCKS! on which he was a series regular.\n\nOn the film side, Patch can be seen in the Blumhouse features THE FIRST PURGE and CAM. He also starred in the independent films , SULLY, BRITTANY RUNS A MARATHON, and CABRINI. In 2017, Darragh starred in THE DEPTHS, and won Best Supporting Actor at the Los Angeles Film Awards. Upcoming: RESENTMENT, and THE UNION (Netflix).\n\nAs a writer, Patch has developed three television pilots, including two with fellow Juilliard grad Erin Gann. Their feature BIRTHRITE wrapped principle photography in June of 2023.","name":"Patch Darragh","primary":true}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"帕奇·达拉格以优异的成绩毕业于茱莉亚音乐学院，开始了他的职业生涯，在许多国家的顶级地区剧院以及百老汇内外最重要的剧院中，在屡获殊荣的新剧和复兴中扮演了重要角色。他积累了大量的电视作品，最近在屡获殊荣的 HBO 剧集《继承》中，他从第二季到第四季扮演 WayStar Royco 董事会成员雷·肯尼迪。Patch在《法律与秩序：SVU》、《梅赛德斯先生》、《最响亮的声音》、《路径》、《朗迈尔》、《浮桥帝国》和《万花筒》中也有值得注意的弧线。他最出名的可能是 Netflix 热门剧集《一切都很糟糕》中的可爱爸爸！他是系列赛的常客。","name":"帕奇·达拉格","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"帕奇·達拉格以優異的成績畢業於茱莉亞音樂學院，開始了他的職業生涯，在許多國家的頂級地區劇院以及百老匯內外最重要的劇院中，在屢獲殊榮的新劇和復興中扮演了重要角色。他積累了大量的電視作品，最近在屢獲殊榮的 HBO 劇集《遺密繼承人》中，他從第二季到第四季扮演 WayStar Royco 董事會成員雷·肯尼迪。Patch 在《法律與秩序：SVU》、《梅賽德斯先生》、《最響亮的聲音》、《路徑》、《朗邁爾》、《浮橋帝國》和《萬花筒》中也有值得注意的弧線。他最出名的可能是 Netflix 熱門劇集《一切都很糟糕》中的可愛爸爸！他是系列賽的常客。","name":"帕奇·達拉格","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Пэтч Дара","primary":false}}]}}}}