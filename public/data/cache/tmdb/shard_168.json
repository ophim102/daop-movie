{"version":1,"entries":{"person_38458_translations":{"at":1772689422627,"data":{"id":38458,"translations":[{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Jasmin Schwiers ist eine deutsche Schauspielerin.\n\nNach ihrem Fernsehdebüt mit Die Nacht der Nächte – School’s out (1997) hatte Schwiers 1998 ihren Durchbruch als Tochter von Serienmutter Rita Kruse (Gaby Köster) in der RTL-Comedy-Serie Ritas Welt. Ihr Kinodebüt gab Schwiers im Folgejahr in Otto Alexander Jahrreiss' Komödie Alles Bob! Zum Zeitpunkt ihres Schulabschlusses hatte sie bereits bei etwa 20 Produktionen mitgewirkt.\n\nJasmin Schwiers lebt in Köln und ist mit dem Schauspieler Jan van Weyde verheiratet. Im August 2014 kam ihre gemeinsame Tochter zur Welt. Ihr Bruder Rene ist Musiker in der Kölsch-Rock-Gruppe Kasalla.","name":"Jasmin Schwiers","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jasmin Schwiers is a German actress.","name":"","primary":false}},{"iso_3166_1":"CH","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"야스민 슈비어스","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"یاسمین شوییورز","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Жасмин Швиерс","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"雅斯密·史瓦爾斯","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"雅斯密·史瓦爾斯","primary":false}}]}},"person_3479221_translations":{"at":1772689426955,"data":{"id":3479221,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"Eng