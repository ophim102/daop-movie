:false,"languages":["zh"],"last_air_date":"2026-02-15","last_episode_to_air":{"id":6899773,"name":"Episode 40","overview":"","vote_average":0,"vote_count":0,"air_date":"2026-02-15","episode_number":40,"episode_type":"finale","production_code":"","runtime":45,"season_number":1,"show_id":282558,"still_path":"/u9cgECH8GrAuS6RSQ0TWRjz0VtI.jpg"},"name":"Cây Sinh Mệnh","next_episode_to_air":null,"networks":[{"id":521,"logo_path":"/2aXk02xBwG2Nhu4lftabfqSpwY3.png","name":"CCTV-8","origin_country":"CN"},{"id":1330,"logo_path":"/fNxBFqWr7eWEgNeBDvvCxsSItXx.png","name":"iQiyi","origin_country":"CN"}],"number_of_episodes":40,"number_of_seasons":1,"origin_country":["CN"],"original_language":"zh","original_name":"生命树","overview":"Vào những năm 1990 của thế kỷ trước, huyện Mã Trị trên cao nguyên Thanh Hải phụ thuộc nặng nề vào nông nghiệp và chăn nuôi, từng rơi vào cảnh nghèo đói kéo dài. Khu vực Bác La Mộc La lân cận là vùng đất không người, giàu tài nguyên khoáng sản và động vật hoang dã, khiến các nhóm săn trộm và khai thác trái phép vì lợi nhuận khổng lồ mà tàn sát, khai thác bừa bãi. Phó huyện trưởng huyện Mã Trị là Đa Kiệt, với sự ủng hộ của huyện trưởng Lâm Bồi Sinh, đã thành lập đội tuần núi. Ban đầu, mục đích của đội là thăm dò khoáng sản trong vùng đất không người nhằm xóa đói giảm nghèo. Nhưng sau khi tận mắt chứng kiến cảnh linh dương Tây Tạng bị thảm sát, Đa Kiệt đã dốc toàn bộ tâm huyết cho sự nghiệp bảo vệ môi trường. Trong đội tuần núi, nữ cảnh sát trẻ Bạch Cúc trở thành biến số định mệnh của Đa Kiệt. Cô là trẻ mồ côi được bác sĩ chi viện Tây Tạng Trương Cần Cần nhận nuôi, cũng là cô con gái út gan dạ, dám xông pha của nhà họ Bạch.","popularity":5.2022,"poster_path":"/ppFUg9nXeJ4FWj0HcuiIFLiJdAg.jpg","production_companies":[{"id":148869,"logo_path":"/1uiCvFIkqy90sifkKMAMFF2efUi.png","name":"Daylight Entertainment Co., Ltd.","origin_country":"CN"}],"production_countries":[{"iso_3166_1":"CN","name":"China"}],"seasons":[{"air_date":"2026-01-30","episode_count":40,"id