nslations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jason O'Mara (born August 6, 1972) is an Irish actor. He has starred in the American television network dramas In Justice, Life on Mars, Terra Nova and Vegas. He is also known for voicing DC Comics' superhero Batman in the animated films Son of Batman, Batman vs. Robin, and Batman: Bad Blood as well as Justice League: War and Justice League: Throne of Atlantis.  Description above from the Wikipedia Jason O'Mara licensed under CC-BY-SA, full list of contributors on Wikipedia.","name":"Jason O'Mara","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"Jason O'Mara ist ein irischer Schauspieler. Er spielte in den US-amerikanischen Fernsehserien „In Justice“, „Life on Mars“, „Terra Nova“ und „Vegas“ mit. Außerdem ist er bekannt als Synchronsprecher des DC-Comics-Superhelden Batman in den Animationsfilmen „Son of Batman“, „Batman vs. Robin“ und „Batman: Bad Blood“ sowie in „Justice League: War“ und „Justice League: Throne of Atlantis“.","name":"","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"PL","iso_639_1":"pl","name":"Polski","english_name":"Polish","data":{"biography":"Jason urodził się w Dublinie w Irlandii. Po ukończeniu dublińskiego collegu św. Trójcy przeniósł się do Londynu, aby dalej prowadzić swoja karierę aktorską. Zaczął pracować w teatrze i w 2002 roku został nominowany w kategorii Najlepszy drugoplanowy aktor. W 2001 roku debiutował w filmie Steven'a Spielberga pt.\" Kompania braci\". Grywał również role gościnne, m.in. w \"CSI Miami\", \"The Closer\" i \"Criminal Minds\". Przeprowadzka w 2002 roku do Stanów Zjednoczonych dała Jasonowi okazję do grania w Hollywood kilku odrębnych serialach jednocześnie. Jason i jego rodzina dzielą czas między wschodnią i zachodnia część Ameryki i odwiedzają Irlandię kiedy tylko mogą.","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"傑森·歐瑪拉","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ジェイソン・オマラ","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"杰森·奥玛拉","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"ג'ייסון או'מרה","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Джейсон О'Мара","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"傑森·歐瑪拉","primary":false}}]}},"movie_957461_keywords":{"at":1773319434312,"data":{"id":957461,"keywords":[{"id":7606,"name":"dictatorship"},{"id":10235,"name":"family relationships"},{"id":6460,"name":"chile"},{"id":187056,"name":"woman director"}]}},"person_16880_translations":{"at":1773319434813,"data":{"id":16880,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Buyandulam Daramdadi","primary":false}},{"iso_3166_1":"MN","iso_639_1":"mn","name":"","english_name":"Mongolian","data":{"biography":"","name":"Buyandulam Daramdadi","primary":true}}]}},"person_1772592_translations":{"at":1773319436954,"data":{"id":1772592,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Mónica Alonso","primary":false}},{"iso_3166_1":"MX","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"","name":"Mónica Alonso","primary":true}}]}},"person_4315020_translations":{"at":1773319437638,"data":{"id":4315020,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English