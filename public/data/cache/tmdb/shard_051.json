tions":{"at":1772689469111,"data":{"id":1897341,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"姜珮瑶，1994年3月10日出生于北京市，中国内地女演员，毕业于北京电影学院2016级硕士研究生班。\n\n2014年，主演青春剧《这个男人有点慌》。2016年8月，主演的都市轻科幻电影《人工智能：伏羲觉醒》上映。2017年10月，主演的剧情片《灰烬重生》首映。2018年1月，主演的警匪电影《英雄本色2018》上映 。2019年7月，主演的青春励志言情剧《亲爱的，热爱的》播出；8月，主演的警匪动作片《使徒行者2：谍影行动》上映。2021年3月，与马思纯、白敬亭合作主演的都市情感剧《你是我的城池营垒》开播。","name":"姜珮瑶","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Jiang Pei Yao is a mainland Chinese actress who graduated from the undergraduate program of the Acting Department at Beijing Film Academy and studies in the Class of '16 Master's program at Beijing Film Academy. In 2014, she made her debut as Zhang Jiaqi in the comedy film \"Dandy Diary\".","name":"Jiang Peiyao","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"Khương Bội Dao, là một nữ diễn viên người Trung Quốc, cô tốt nghiệp khoa diễn xuất Đại học Điện ảnh Bắc Kinh và là học viên cử nhân lớp 2016 của trường này. Năm 2014, cô ra mắt với vai diễn trong bộ phim hài \"Người Đàn Ông Này Có Vẻ Hơi Loạn.\" Năm 2015, cô tham gia vào bộ phim \"Playing Magic Paradise: The Big Bang of Love.\" Vào ngày 28 tháng 7 năm 2016, cô đóng vai chính trong bộ phim tâm lý “Truy Tung”. 19 tháng 6 năm 2017, cô tham gia bộ phim trẻ trung do Phùng Tiểu Cương sản xuất có tên \"Từng Là Tuổi Trẻ\", và vào ngày 28 tháng 9, cô tham gia bộ phim hành động tội phạm \"Phong Lâm Hỏa Sơn\" Vào ngày 18 tháng 1 năm 2018, bộ phim hành động tội phạm \"Bản Sắc Anh Hùng 2018\" mà cô đóng vai chính đã ra mắt.","name":"Khương Bội Dao","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"姜珮瑤","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"姜珮瑤，1994 年 3 月 10 日出生於北京市，中國內地女演員，畢業於北京電影學院 2016 級碩士研究生班。\n\n2014 年，主演青春劇《這個男人有點慌》。2016 年 8 月，主演的都市輕科幻電影《人工智能：伏羲覺醒》上映。2017 年 10 月，主演的劇情片《灰燼重生》首映。2018 年 1 月，主演的警匪電影《英雄本色 2018》上映 。2019 年 7 月，主演的青春勵志言情劇《親愛的，熱愛的》播出；8 月，主演的警匪動作片《使徒行者 2：諜影行動》上映。2021 年 3 月，與馬思純、白敬亭合作主演的都市情感劇《你是我的城池營壘》開播。","name":"姜珮瑤","primary":false}}]}},"person_5103499_translations":{"at":1772689473098,"data":{"id":5103499,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李逸，中国男，729声工场配音演员，配音代表作：电视剧《雪鹰领主》。","name":"李逸","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"李逸，中國男，729 聲工場配音演員，配音代表作：電視劇《雪鷹領主》。","name":"李逸","primary":false}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Li Yi","primary":false}}]}},"person_4988208_translations":{"at":1772689474028,"data":{"id":4988208,"translations":[{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"권성준","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kwon Seong-joon","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"权圣晙","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"權聖晙","primary":false}}]}},"person_1457880_translations":{"at":1772689476792,"data":{"id":1457880,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Shanshan Chunyu was born on 25 November 1967 in Qingdao, Shandong, China. He is an actor, known for Tian xia wu di zhang men ren (2000), Kung Fu Vampire (1993) and The Hidden Fox (2022)","name":"Chunyu Shanshan","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"淳于珊珊，11月25日出生于山东省青岛市，毕业于北京电影学院，中国内地男演员。1986年，淳于珊珊签约香港银都机构，开始演艺生涯。1987年首次出演武侠片《黄河大侠》。1989年主演电影《百变神偷》。1992年接受新加坡政府邀请，加盟新加坡电视台 。1993年出演在新加坡的第一部电视剧《荡寇英雄》。","name":"淳于珊珊","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"淳于珊珊","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Чуньюй Шань Шань","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"Thuần Vu San San","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"淳于珊珊，11 月 25 日出生於山東省青島市，畢業於北京電影學院，中國內地男演員。1986 年，淳于珊珊簽約香港銀都機構，開始演藝生涯。1987 年首次出演武俠片《黃河大俠》。1989 年主演電影《百變神偷》。1992 年接受新加坡政府邀請，加盟新加坡電視台 。1993 年出演在新加坡的第一部電視劇《蕩寇英雄》。","name":"淳于珊珊","primary":false}}]}}}}