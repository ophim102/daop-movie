66_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ジョー・ティペット","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"جو تیپت","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"","name":"Τζο Τίπετ","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"جو تيبيت","primary":false}}]}},"tv_282158_keywords":{"at":1772469957668,"data":{"id":282158,"results":[{"name":"remake","id":9714},{"name":"3d animation","id":278823},{"name":"donghua","id":315535},{"name":"based on web novel","id":318933}]}},"person_189001_translations":{"at":1772469959953,"data":{"id":189001,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"David Haysom is a Canadian film and television actor.","name":"David Haysom","primary":true}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"","name":"","primary":false}}]}},"person_1402734_translations":{"at":1772469962094,"data":{"id":1402734,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Yiu Wai","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"姚炜本名金瑛瑛，四十年代末出生于上海。自幼爱好唱歌，一次在歌厅被歌唱老师许佩邀请上台代唱，从此一鸣惊人，获歌厅邀请加盟，并于1973年在港开始职业演唱。她曾是丽的电视的合约歌星，也曾与宝丽金签下唱片合约。姚炜常受邀到东南亚各地登台演出。与新加坡颇有渊源的姚炜，早年经常来新登台。曾受邀在台北大歌厅驻唱两年之久。 　　姚炜歌而优则演，于1978年签约香港无线电视。电视作品包括《势不两立》、《奋斗》、《无双谱》、《情谜》、《飞鹰》、《神探霹雳》、《北斗双雄》、《鳄鱼潭》等。此外，她也曾参演多部电影，如《金大班的最后一夜》、《塘西故事》、《再起风云》、《鬼域》、《鬼马智多星》、《鲨鱼烧卖》、《爱人女神》、《红番区》、《香江岁月》、《赤裸羔羊》及《海上花》等。她在《势不两立》中的豪门怨妇的角色，奠定了她在演艺圈的地位。 　　姚炜最受瞩目的代表作则是由白先勇名著改编而成的《金大班的最后一夜》。","name":"姚炜","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"姚煒本名金瑛瑛，四十年代末出生於上海。自幼愛好唱歌，一次在歌廳被歌唱老師許佩邀請上台代唱，從此一鳴驚人，獲歌廳邀請加盟，並於 1973 年在港開始職業演唱。她曾是麗的電視的合約歌星，也曾與寶麗金簽下唱片合約。姚煒常受邀到東南亞各地登台演出。與新加坡頗有淵源的姚煒，早年經常來新登台。曾受邀在台北大歌廳駐唱兩年之久。\n\n姚煒歌而優則演，於 1978 年簽約香港無線電視。電視作品包括《勢不兩立》、《奮鬥》、《無雙譜》、《情謎》、《飛鷹》、《神探霹靂》、《北鬥雙雄》、《鱷魚潭》等。此外，她也曾參演多部電影，如《金大班的最後一夜》、《塘西故事》、《再起風雲》、《鬼域》、《鬼馬智多星》、《鯊魚燒賣》、《愛人女神》、《紅番區》、《香江歲月》、《赤裸羔羊》及《海上花》等。她在《勢不兩立》中的豪門怨婦的角色，奠定了她在演藝圈的地位。\n\n姚煒最受矚目的代表作則是由白先勇名著改編而成的《金大班的最後一夜》。","name":"姚煒","primary":false}},{"iso_3166_1":"SK","iso_639_1":"sk","name":"Slovenčina","english_name":"Slovak","data":{"biography":"","name":"Yiu Wai","primary":false}}]}},"person_1834148_translations":{"at":1772469964990,"data":{"id":1834148,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Lapisara Intarasut, nicknamed Apple, is a singer and actress from Kamphaeng Phet Province, Thailand. She has an older brother. She is studying at Faculty of Fine and Applied Arts, Major in Acting & Directing, from Sinakharinwirot University (Prasanmit). Lapisara would like to be a producer or a director.\n\nWhen she was 16, she moved to Bangkok to take part in a reality TV show, The Star Season 7. She explained that she signed up to audition to help the family financially.","name":"Lapisara Intarasut","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"Lapisara Intarasut","primary":true}}]}},"person_3261027_translations":{"at":1772469966637,"data":{"id":3261027,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Kim Hyun-jin","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"韩国演员、模特，2015年以模特身份出道，2020年通过《糖涂层》作为演员正式出道。2022年主演《青春应援Cheer Up》，并凭借该剧获得同年SBS演技大奖男子新人演技奖。2024年，主演《我光明正大地梦想成为灰姑娘》。2025年，出演《芭妮与哥哥们》。2026年，主演出道后首部男主长剧《恋爱恐慌症》。","name":"金贤镇","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"김현진","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"金賢鎮","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Kim Hyun Jin é um modelo e ator sul-coreano que nasceu em 24 de agosto de 1996, em Seosan, província de Chungcheong do Sul, Coreia do Sul. Ele começou a modelar na década de 2010 e trabalhou com várias marcas na Hera Seoul Fashion Week de 2016. Em 2020, ele apareceu na série dramática “Is the Delivery on Time?” Em 2022, ele apareceu na série dramática “Cheer Up!”","name":"Kim Hyun Jin","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"韓國演員、模特，2015 年以模特身份出道，2020 年通過《糖塗層》作為演員正式出道。2022 年主演《青春應援 Cheer Up》，並憑借該劇獲得同年 SBS 演技大獎男子新人演技獎。2024 年，主演《我光明正大地夢想成為灰姑娘》。2025 年，出演《芭妮與哥哥們》。2026 年，主演出道後首部男主長劇《戀愛恐慌症》。","name":"金賢鎮","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ким Хён-джин","primary":false}}]}},"tv_240446_credits":{"at":1772469983024,"data":{"cast":[{"adult":false,"gender":1,"id":1006594,"known_for_department":"Acting","name":"Wang Ziwen","original_name":"王子文","popularity":1.9414,"profile_path":"/qcbGx4uKq3HAbAZRsZkrOztVgGe.jpg","character":"Li Xiaoxi","credit_id":"65651b5ea35c8e011bfdbc55","order":0},{"adult":false,"gender":2,"id":2365187,"known_for_department":"Acting","name":"Liu Yuning","original_name":"刘宇宁","popularity":3.4582,"profile_path":"/6JvMALlglmZB5gutlheu4J5KjAI.jpg","character":"Xiao Bei","credit_id":"65651b70a35c8e0138cb3d62","order":1},{"adult":false,"gender":1,"id":1241445,"known_for_department":"Acting","name":"Jiang Xin","original_name":"蒋欣","popularity":2.1422,"profile_path":"/jwUQ7B22K0rlRtAMegnkMR2O2t5.jpg","character":"Yu","credit_id":"6858cc969c4ca26d95399075","order":2},{"adult":false,"gender":2,"id":20