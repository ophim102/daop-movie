ame":"","primary":false}},{"iso_3166_1":"DK","iso_639_1":"da","name":"Dansk","english_name":"Danish","data":{"biography":"idsel Siem Koch er uddannet på Skuespillerskolen i Odense 2013.","name":"Sidsel Siem Koch","primary":true}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Сідсель Сім Кох","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Сидсель Сим Кох","primary":false}}]}},"person_2692283_translations":{"at":1772689470240,"data":{"id":2692283,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Janelle James is an American comedian, actress, and writer. She is best known for her role as Ava Coleman in the ABC television series Abbott Elementary, for which she won a Screen Actors Guild Award, and an NAACP Image Award, in addition to nominations for three Primetime Emmy Awards, and a Golden Globe Award.","name":"Janelle James","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"DE","iso_639_1":"de","name":"Deutsch","english_name":"German","data":{"biography":"James stammt ursprünglich von den Amerikanischen Jungferninseln. Sie wuchs als ältestes von neun Kindern auf. In ihrer Heimat betrieb ihr Vater ein Restaurant sowie einen Food Truck, in dem James bereits als Siebenjährige arbeitete.\n\nIm Alter von 16 Jahren verlegte sie ihren Wohnort auf das Festland der USA. Sie wohnte zunächst mit ihrer Mutter in Maryland, lebte danach 15 Jahre in New York und wohnte anschließend in Illinois. Nach der Ausstrahlung der 1. Staffel von Abbott Elementary im Jahr 2021 verlegte James teilweise ihren Wohnort nach Los Angeles. Sie lebt seitdem gleichermaßen in New York und Los Angeles.\n\nVor ihrer beruflichen Karriere im Bereich Comedy studierte James Modedesign am Fashion Institute of Technology in New York, beendete ihr Studium dort aber nicht. Während ihrer Zeit an der Hochschule gründete sie den Essenslieferservice „Joy of Not Cooking“ und arbeitete u. a. als Partyorganisatorin für eine PR-Firma für Mode.\n\nJames ist Mutter zweier Söhne.","name":"Janelle James","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ジャネル・ジェームズ","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"ג'אנל ג'יימס","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Жанель Джеймс","primary":false}}]}},"person_2511528_translations":{"at":1772689480639,"data":{"id":2511528,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Khushi Hajare","primary":false}},{"iso_3166_1":"IN","iso_639_1":"hi","name":"हिन्दी","english_name":"Hindi","data":{"biography":"","name":"Khushi Hajare","primary":true}}]}}}}