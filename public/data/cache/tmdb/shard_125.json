:"","name":"片冈凛","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"片岡凜","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"카타오카 린","primary":false}}]}},"person_1020859_translations":{"at":1772647179403,"data":{"id":1020859,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Sung Dong-il is a South Korean actor. Sung made his acting debut in theater in 1987, then was recruited at the 1991 SBS open talent auditions.","name":"Sung Dong-il","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"성동일","primary":true}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"成東鎰（성동일，Sung Dong-il），韓國男演員，常見譯名為成東日。1991年SBS第1期公開招募演員。1985年即入門演藝圈，1991年加入SBS演藝人才第一期培訓班，開始了其電視生涯。","name":"成東鎰","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"“红袜子”成东日1985年即入门演艺圈，1991年加入SBS 演艺人才第一期培训班开始了电视生涯，出演了《蜗牛》、《骑自行车的女子》、《野人时代》、《我跑》、《巴黎恋人》、《绿蔷薇》等多部优秀剧集，凭借坚持和钻研演技的毅力一步步成为明星，尤其是在1999年播出的SBS电视剧《银实》中，成东日扮演的穿红袜子的剧场流氓杨正八让韩国观众掉进了爆笑的旋涡之中，他也从此之后都被亲切地称为“红袜子”成东日。1995年他在SBS《骑自行车的女人》时遇见了舞蹈家李贤淑，倾心于其跳舞的样子而展开了坚持不懈的追求，最终在2001年二人步入了婚约的殿堂，此后德成东日工作也更加努力，是演艺圈中孝顺儿子和顾家丈夫的代表。2006年他在电影《丑女大翻身》中和朱镇模费尽心思将金雅中包装成为性感女歌手，再次展现了自己的喜剧天分而博得了观众们的掌声。","name":"成东日","primary":false}},{"iso_3166_1":"FR","iso_639_1":"fr","name":"Français","english_name":"French","data":{"biography":"","name":"Sung Dong-il","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Сон Дон Иль","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"سونغ دونغ ايل","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"“紅襪子”成東日 1985 年即入門演藝圈，1991 年加入 SBS 演藝人才第一期培訓班開始了電視生涯，出演了《蝸牛》、《騎腳踏車的女子》、《野人時代》、《我跑》、《巴黎戀人》、《綠薔薇》等多部優秀劇集，憑藉堅持和鑽研演技的毅力一步步成為明星，尤其是在 1999 年播出的 SBS 電視劇《銀實》中，成東日扮演的穿紅襪子的劇場流氓楊正八讓韓國觀眾掉進了爆笑的旋渦之中，他也從此之後都被親切地稱為“紅襪子”成東日。1995 年他在 SBS《騎腳踏車的女人》時遇見了舞蹈家李賢淑，傾心於其跳舞的樣子而展開了堅持不懈的追求，最終在 2001 年二人步入了婚約的殿堂，此後德成東日工作也更加努力，是演藝圈中孝順兒子和顧家丈夫的代表。2006 年他在電影《醜女大翻身》中和朱鎮模費盡心思將金雅中包裝成為性感女歌手，再次展現了自己的喜劇天分而博得了觀眾們的掌聲。","name":"成東日","primary":false}},{"iso_3166_1":"UA","iso_639_1":"uk","name":"Український","english_name":"Ukrainian","data":{"biography":"","name":"Сон Дон Іль","primary":false}}]}},"tv_233833_detail_vi-VN":{"at":1772647199650,"data":{"adult":false,"backdrop_path":"/pHhGVPOi9qI6CVYIrgZ2VWflg0u.jpg","created_by":[{"id":2995812,"credit_id":"69a02db07acbc929adefef61","name":"Jo Sung-hee","original_name":"Jo Sung-hee","gender":1,"profile_path":null}],"episode_run_time":[],"first_air_date":"2026-02-20","genres":[{"id":9648,"name":"Phim Bí Ẩn"},{"id":18,"name":"Phim Chính Kịch"},{"id":10751,"name":"Phim Gia Đình"}],"homepage":"","id":233833,"in_production":true,"languages":["ko"],"last_air_date":"2026-02-28","last_episode_to_air":{"id":6841833,"name":"Episode 4","overview":"","vote_average":0,"vote_count":0,"air_date":"2026-02-28","episode_number":4,"episode_type":"standard","production_code":"","runtime":68,"season_number":1,"show_id":233833,"still_path":"/oTXO8EbUn8fdaNVUCrmlHV93B0S.jpg"},"name":"찬란한 너의 계절에","next_episode_to_air":{"id":6841834,"name":"Episode 5","overview":"","vote_average":0,"vote_count":0,"air_date":"2026-03-06","episode_number":5,"episode_type":"standard","production_code":"","runtime":null,"season_number":1,"show_id":233833,"still_path":null},"networks":[{"id":97,"logo_path":"/pOSCKaZhndUFYtxHXjQOV6xJi1s.png","name":"MBC","origin_country":"KR"}],"number_of_episodes":12,"number_of_seasons":1,"origin_country":["KR"],"original_language":"ko","original_name":"찬란한 너의 계절에","overview":"","popularity":14.5526,"poster_path":"/eUkIxWK9KhLQLPQct9G8HeY61Rj