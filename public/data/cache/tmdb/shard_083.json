,{"adult":false,"gender":0,"id":3685178,"known_for_department":"Writing","name":"Irene Insot","original_name":"ไอรีน อินสด","popularity":0.4207,"profile_path":null,"credit_id":"65828a48b1131f5232ae79cb","department":"Writing","job":"Writer"},{"adult":false,"gender":2,"id":2451192,"known_for_department":"Directing","name":"Noppharnach Chaiyahwimhon","original_name":"นพณัช ชัยวิมล","popularity":1.6549,"profile_path":"/jLgugmt2xnyA9YAK7nZaegW8fE3.jpg","credit_id":"65828a68880551409d2764c1","department":"Production","job":"Producer"},{"adult":false,"gender":1,"id":4124844,"known_for_department":"Writing","name":"Issaraporn Kuntisuk","original_name":"อิสราภรณ์ คุณติสุข","popularity":0.6429,"profile_path":null,"credit_id":"65828a2808354745553e5b2d","department":"Writing","job":"Writer"}],"id":217826}},"person_13526_translations":{"at":1772647209443,"data":{"id":13526,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Noah Strausser Speer Wyle is an American actor, producer, director, and writer. He is best know for his role as John Carter in the NBC medical drama ER, earning nominations for three Golden Globe Awards and five Primetime Emmy Awards.","name":"Noah Wyle","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"💥Ноа Страуссер Спир Уайли. Родился в 1971-ом году в Голливуде, Калифорния, США. Рос в семье со старшей сестрой и младшим братом. Отец работал инженером-электриком, а мать была медсестрой. Учился в школе в Охае. Работает актёром и продюсером. Дважды женат: на визажисте Трейси Уорбин (родились сын Оуэн и дочь Оден) и с 2014-го на актрисе Саре Уэлс, у пары дочь Фрэнсис\n\n🏆Главные награды🏆: Эмми (2025) [Больница Питт], Золотой глобус (2026) [Больница Питт]\n\n🎬Главные проекты🎬: «Больница Питт» (2025), «Скорая помощь» (1994), «Рухнувшие небеса» (2011), «Донни Дарко» (2001)\n\n⭐Интересный факт⭐: Ноа прославился тем, что почти всю карьеру играет врачей, в сериалах «Скорая помощь» и «Больница Питт», из-за чего его часто называют одним из самых узнаваемых докторов на экране","name":"Ноа Уайли","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Noah Wyle (nacido el 4 de junio de 1971) es un actor de cine, televisión y teatro estadounidense. Es mejor conocido por sus papeles en ER y en la franquicia The Librarian.","name":"","primary":false}},{"iso_3166_1":"PL","iso_639_1":"pl","name":"Polski","english_name":"Polish","data":{"biography":"Urodził się w Hollywood jako jeden z szóstki dzieci inżyniera elektrycznego i pielęgniarki. Uczestniczył w programie sztuk teatralnych Northwestern University w trakcie nauki w szkole średniej. Po ukończeniu szkoly średniej pobierał lekcje gry aktorskiej u Larry Moss. w tym czasie mieszkał w małym mieszkanku na Hollywood Boulevard. Debiutował epizodem w filmie \"Pożądanie na pustyni\" [85]. Na dużym ekranie po raz pierwszy pojawił się w filmie \"Crooked Hearts\". Popularność zawdzięcza serialowi \"Ostry dyżur\", gdzie gra doktora Johna Cartera od pilotowego odcinka z 1994 roku. Przyniosła mu szereg nagród i wyróżnień, m.in: 5 nominacji do \"Emmy\" i trzy zgłoszenia do \"Złotego Globa\". Z ciekawostek - w 1996 r pojawił się w \"Ulicy sezamkowej\" (15.11.1995) oraz raz w serialu \"Przyjaciele\", grając dr Jeffrey Rosen w odcinku \"One with Two Parts, The Part 2 \"(epizod 1.16/ 23.02.1995)","name":"","primary":false}},{"iso_3166_1":"HU","iso_639_1":"hu","name":"Magyar","english_name":"Hungarian","data":{"biography":"Noah Strausser Speer Wyle (Hollywood, Kalifornia, 1971. június 4. –) amerikai film-, televíziós és színpadi színész.\n\nLegismertebb televíziós szerepe Dr. John Carter a Vészhelyzet (1994–2009) című amerikai kórházsorozatban. Alakításával három Golden Globe- és öt Primetime Emmy-jelölést szerzett. Fontosabb alakítása volt még Flynn Carsen a Titkok könyvtára televíziós filmekben és sorozatban (2004–2018), valamint Tom Mason az Éghasadás (2011–2015) című sci-fi-sorozatban.\n\nFontosabb filmszerepei közé tartozik az Egy becsületbeli ügy (1992), A szilikonvölgy kalózai (1999), a Donnie Darko (2001) és a W. – George W. Bush élete (2008).","name":"","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"诺亚·怀尔（Noah Wyle，1971年6月4日-），美国电影、电视和戏剧演员。他最出名的是他在 ER 和 The Librarian 系列中的角色。","name":"诺亚·怀勒","primary":false}},{"iso_3166_1":"IL","iso_639_1":"he","name":"עִבְרִית","english_name":"Hebrew","data":{"biography":"","name":"נואה ויילי","primary":false}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"IR","iso_639_1":"fa","name":"فارسی","english_name":"Persian","data":{"biography":"","name":"نوآ وایل","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"諾亞·懷爾（Noah Wyle，1971 年 6 月 4 日-），美國電影、電視和戲劇演員。他最出名的是他在 ER 和 The Librarian 系列中的角色。","name":"諾亞·懷勒","primary":false}},{"iso_3166_1":"GR","iso_639_1":"el","name":"ελληνικά","english_name":"Greek","data":{"biography":"","name":"Νόα Γουάιλ","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"ノア・ワイリー","primary":false}},{"iso_3166_1":"HY","iso_639_1":"hy","name":"","english_name":"Armenian","data":{"biography":"","name":"Նոյա Ուայլի","primary":false}},{"iso_3166_1":"BG","iso_639_1":"bg","name":"български език","english_name":"Bulgarian","data":{"biography":"","name":"Ноа Уайли","primary":false}},{"iso_3166_1":"BY","iso_639_1":"be","name":"беларуская мова","english_name":"Belarusian","data":{"biography":"","name":"Ноа Уайлі","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"نوح وايلي","primary":false}},{"iso_3166_1":"RS","iso_639_1":"sr","name":"Srpski","english_na