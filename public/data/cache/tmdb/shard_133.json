alse}}]}},"person_2027615_translations":{"at":1772469965134,"data":{"id":2027615,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Wang Xiao","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王骁，1978年5月4日出生于南京。中国内地男演员。\n\n2010年，王骁因出演情感伦理剧《迷失洛杉矶》而进入观众视野 ，之后参演电视剧《夏妍的秋天》和《下南洋》。2011年首次与妈妈王馥荔合作出演家庭疗伤剧《我们是一家人》。2012年参演都市商战悬爱大戏《盛夏晚晴天》，而受到广泛关注，同年出演基努里维斯指导电影《太极侠》 。2013年出演现代都市家庭情感剧《妻子的秘密》中饰演地瓜。2014年出演《老婆大人是80后》 ；2015年出演电视剧《白鹿原》；2016年出演电视剧《三生三世十里桃花》及《漂亮的李慧珍》，同年10月出演电视剧《因法之名》。2018年，参演古装玄幻剧《三生三世枕上书》。","name":"王骁","primary":true}},{"iso_3166_1":"VN","iso_639_1":"vi","name":"Tiếng Việt","english_name":"Vietnamese","data":{"biography":"","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"王驍","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"王驍，1978 年 5 月 4 日出生於南京。中國內地男演員。\n\n2010 年，王驍因出演情感倫理劇《迷失洛杉磯》而進入觀眾視野 ，之後參演電視劇《夏妍的秋天》和《下南洋》。2011 年首次與媽媽王馥荔合作出演家庭療傷劇《我們是一家人》。2012 年參演都市商戰懸愛大戲《盛夏晚晴天》，而受到廣泛關注，同年出演基努裏維斯指導電影《太極俠》 。2013 年出演現代都市家庭情感劇《妻子的秘密》中飾演地瓜。2014 年出演《老婆大人是 80 後》 ；2015 年出演電視劇《白鹿原》；2016 年出演電視劇《三生三世十裏桃花》及《漂亮的李慧珍》，同年 10 月出演電視劇《因法之名》。2018 年，參演古裝玄幻劇《三生三世枕上書》。","name":"王驍","primary":false}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Ван Сяо","primary":false}}]}},"tv_289690_credits":{"at":1772469966008,"data":{"cast":[{"adult":false,"gender":1,"id":1875826,"known_for_department":"Acting","name":"Yeon Woo","original_name":"연우","popularity":4.632,"profile_path":"/aXroCR7GA9DKnTxppJComTHrRvC.jpg","character":"Kim Bi-ah","credit_id":"680897c2c96e0dcc05ee3800","order":0},{"adult":false,"gender":2,"id":3261027,"known_for_department":"Acting","name":"Kim Hyun-jin","original_name":"김현진","popularity":1.229,"profile_path":"/2bKZb6DK01ERmBciiTlMEMnisKl.jpg",