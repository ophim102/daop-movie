{"id":1254052,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Koki Uchiyama (内山 昂輝, Uchiyama Kōki, August 16, 1990) is a Japanese actor, voice actor (seiyū) and singer from Saitama Prefecture. He is affiliated with Himawari Theater Group. In 2011, he won Best Rookie Actor at the 5th Seiyū Awards, and in 2015, Best Voice Actor at the Tokyo Anime Awards.","name":"Koki Uchiyama","primary":false}},{"iso_3166_1":"JP","iso_639_1":"ja","name":"日本語","english_name":"Japanese","data":{"biography":"","name":"内山昂輝","primary":true}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"우치야마 고키","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"內山昂輝是日本的男性聲優、演員。出身於埼玉縣，所屬公司為向日葵劇團。","name":"內山昂輝","primary":false}},{"iso_3166_1":"ES","iso_639_1":"es","name":"Español","english_name":"Spanish","data":{"biography":"Koki Uchiyama (内山 昂輝, Uchiyama Kōki, 16 de agosto de 1990) es un actor, actor de voz (seiyū) y cantante japonés de la prefectura de Saitama. Está afiliado a la Gekidan Himawari (Compañía Teatral Himawari). En 2011, fue galardonado con el premio al Mejor Actor Revelación en los 5.º Seiyū Awards, y en 2015, al Mejor Actor de Voz en los Tokyo Anime Awards.","name":"Koki Uchiyama","primary":false}},{"iso_3166_1":"TH","iso_639_1":"th","name":"ภาษาไทย","english_name":"Thai","data":{"biography":"","name":"โคกิ อูจิยามะ","primary":false}},{"iso_3166_1":"SA","iso_639_1":"ar","name":"العربية","english_name":"Arabic","data":{"biography":"","name":"كوكي أوتشياما","primary":false}},{"iso_3166_1":"CZ","iso_639_1":"cs","name":"Český","english_name":"Czech","data":{"biography":"","name":"Kóki Učijama","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"","name":"Koki Uchiyama","primary":false}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话