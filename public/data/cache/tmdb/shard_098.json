yếu đuối nhưng thực sự kiên định, hữu dũng hữu mưu.Cả hai đi từ tương ái tương sát đến say đắm trong bể tình, một câu chuyện tình yêu đầy cú ngoặt.","popularity":2.8573,"poster_path":"/bFDLas9u2qxljJS1semTfBmQFBg.jpg","production_companies":[],"production_countries":[],"seasons":[{"air_date":"2023-06-09","episode_count":20,"id":344528,"name":"Season 1","overview":"","poster_path":"/bFDLas9u2qxljJS1semTfBmQFBg.jpg","season_number":1,"vote_average":0}],"spoken_languages":[{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"}],"status":"Ended","tagline":"","type":"Scripted","vote_average":6.6,"vote_count":4}},"person_1632316_translations":{"at":1772647173597,"data":{"id":1632316,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"Choi Myung-gil (최명길) is a South Korean actress.","name":"Choi Myung-gil","primary":false}},{"iso_3166_1":"KR","iso_639_1":"ko","name":"한국어/조선말","english_name":"Korean","data":{"biography":"","name":"최명길","primary":true}},{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"崔明吉（韩语：최명길，1962年11月11日—），韩国女演员，是夺得百想艺术大奖、青龙电影奖及大钟奖三大电影奖的大满贯影后，并凭借《玫瑰色人生》获得南特影展最佳女演员奖。\n\n1981年透过参加MBC第13期艺员训练班而进入韩国娱乐圈。崔明吉是在韩国公众心目中具有极好口碑的演员之一，其成功代表作有《愤怒的眼珠》（MBC，1981）、《风乱》（MBC，1985）、《爱情的风车》（SBS，1991）、《玫瑰色人生》（电影，1994）、《龙之泪》（KBS，1998）、《明成皇后》（KBS，2002）等。并凭借电影《玫瑰色人生》获取韩国青龙电影奖最佳女演员奖、法国电影节最佳女演员奖。\n\n2002年，出演的《明成皇后》第三部（饰演中年的明成皇后）播出后反响强烈，该剧成为2002年KBS收视率最高的电视剧。该剧2004年在中国官方媒体中央电视台播出时，也获得了相当高的收视率，崔明吉凭借出演此剧而人气大涨。\n\n1995年与作家金汉吉结婚（金汉吉曾任韩国文化观光部长官，于1996年当选为韩国国会议员），育有两子。此外，她是演员权律的姨母。","name":"崔明吉","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"崔明吉（韓語：최명길，1962 年 11 月 11 日—），韓國女演員，是奪得百想藝術大獎、青龍電影獎及大鐘獎三大電影獎的大滿貫影後，並憑藉《玫瑰色人生》獲得南特影展最佳女演員獎。\n\n1981 年透過參加 MBC 第 13 期藝員訓練班而進入韓國娛樂圈。崔明吉是在韓國公眾心目中具有極好口碑的演員之一，其成功代表作有《憤怒的眼珠》（MBC，1981）、《風亂》（MBC，1985）、《愛情的風車》（SBS，1991）、《玫瑰色人生》（電影，1994）、《龍之淚》（KBS，1998）、《明成皇后》（KBS，2002）等。並憑藉電影《玫瑰色人生》獲取韓國青龍電影獎最佳女演員獎、法國電影節最佳女演員獎。\n\n2002 年，出演的《明成皇后》第三部（飾演中年的明成皇后）播出後反響強烈，該劇成為 2002 年 KBS 收視率最高的電視劇。該劇 2004 年在中國官方媒體中央電視台播出時，也獲得了相當高的收視率，崔明吉憑藉出演此劇而人氣大漲。\n\n1995 年與作家金漢吉結婚（金漢吉曾任韓國文化觀光部長官，於 1996 年當選為韓國國會議員），育有兩子。此外，她是演員權律的姨母。","name":"崔明吉","primary":false}}]}},"person_3017232_translations":{"at":1772647174169,"data":{"id":3017232,"translations":[{"iso_3166_1":"CN","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"任正斌（曾用名任正彬），出生于湖北省武汉市，中国内地男演员，毕业于中国人民解放军艺术学院。","name":"任正斌","primary":true}},{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Ren Zhengbin","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"任正斌","primary":false}},{"iso_3166_1":"HK","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"汪文斌（曾用名任正彬），出生於湖北省武漢市，中國內地男演員，畢業於中國人民解放軍藝術學院。","name":"汪文斌","primary":false}}]}},"person_6018713_translations":{"at":1772647174814,"data":{"id":6018713,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Catherine McDonough","primary":true}},{"iso_3166_1":"RU","iso_639_1":"ru","name":"Pусский","english_name":"Russian","data":{"biography":"","name":"Катрин МакДонаф","primary":false}}]}},"person_3341430_translations":{"at":1772647174905,"data":{"id":3341430,"translations":[{"iso_3166_1":"US","iso_639_1":"en","name":"English","english_name":"English","data":{"biography":"","name":"Li Weilong","primary":false}},{"iso_3166_1":"BR","iso_639_1":"pt","name":"Português","english_name":"Portuguese","data":{"biography":"Li Weilong, nascido em 1994 é um ator de cinema e televisão na China Continental. Formou-se no Departamento de Performance da Donghua University.","name":"","primary":false}},{"iso_3166_1":"TW","iso_639_1":"zh","name":"普通话","english_name":"Mandarin","data":{"biography":"","name":"Li Weilong","primary":true}},{"iso_3166_1":"CN","